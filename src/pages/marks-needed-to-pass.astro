---
import BaseLayout from '../layouts/BaseLayout.astro';

const faq = [
  {
    question: "What is the passing mark for an 80-mark theory paper at Mumbai University?",
    answer: "For engineering and most courses under Mumbai University following the 80:20 pattern, the passing threshold is 40%. This means you must secure a minimum of 32 marks out of 80 in the end-semester theory examination."
  },
  {
    question: "Do I need to pass theory and internal assessments separately?",
    answer: "Yes. Under Mumbai University regulations, separate passing is mandatory. In an 80:20 engineering scheme, you must secure at least 32/80 in the theory exam and 8/20 in the internal assessments. Scoring well in one cannot compensate for failing in the other."
  },
  {
    question: "How does the calculator determine marks needed to pass?",
    answer: "The calculator applies two rules: first, it checks the independent minimum passing mark for the theory paper. Second, it calculates the combined passing marks needed to reach the overall percentage (typically 40%). It outputs the higher of these two values: Theory Needed = Math.max(Theory Min Pass, Combined Pass Total - Internals Marks Obtained)."
  },
  {
    question: "What happens if I score less than 8 out of 20 in internals?",
    answer: "If your internal assessment score is below the 40% threshold (8/20 for MU Engineering), you fail the internal head of passing. You will be marked as failed in the subject (under backlog/KT) and must reappear for internals or submit supplementary term work in the next term."
  },
  {
    question: "Can I use this calculator to target a specific grade?",
    answer: "Yes. By entering your target overall percentage (e.g. 60% for First Class, 70% for Distinction), the simulator calculates exactly what you must score in the end-semester theory exam to achieve that target grade."
  },
  {
    question: "Are my marks saved or sent to any server?",
    answer: "No. Student Utility Hub values your privacy. All calculator calculations, presets, and sliders run 100% locally in your browser. No academic data is sent to our servers."
  }
];
---

<BaseLayout
  title="Pass Marks Calculator & Target Grade Simulator"
  description="Calculate the minimum theory marks needed to pass your college exams. Supports Mumbai University 80:20 and 75:25 patterns with separate passing rules."
  {faq}
>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Breadcrumb & Header -->
    <nav class="flex mb-4" aria-label="Breadcrumb">
      <ol class="inline-flex items-center gap-1.5 font-mono text-[11px] text-mute">
        <li>
          <a href="/" class="hover:text-ink transition-colors">Home</a>
        </li>
        <li class="flex items-center gap-1.5 select-none">
          <span>/</span>
          <span class="text-body font-semibold">Pass Marks Calculator</span>
        </li>
      </ol>
    </nav>

    <div class="mb-8">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="rounded-full border border-hairline bg-canvas px-3 py-1 font-mono text-[11px] font-semibold text-mute">
          Tool 04
        </span>
        <span class="font-mono text-[11px] uppercase tracking-wider text-mute">
          Exam Prep Planner
        </span>
      </div>
      <h1 class="mt-4 font-sans text-3xl font-semibold tracking-[-0.96px] text-ink sm:text-4xl">
        Pass Marks & Target Marks Calculator
      </h1>
      <p class="mt-2 max-w-2xl text-sm leading-relaxed text-body">
        Find out exactly what you need to score in end-semester theory exams to pass or reach your target grade. Supports separate passing rules for Mumbai University and custom configurations.
      </p>
    </div>

    <!-- Main Tool Workspace -->
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">
      <!-- Calculator Inputs -->
      <div class="flex flex-col gap-6 lg:col-span-7">
        
        <!-- Main Form Card -->
        <div class="rounded-md border border-hairline bg-canvas p-4 sm:p-6 shadow-level-2 transition-colors duration-200">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-mute font-mono mb-6">
            Calculator Setup
          </h2>

          <div class="flex flex-col gap-6">
            <!-- University / Marking Pattern Preset Selection -->
            <div>
              <label for="preset-selector" class="block text-sm font-medium text-ink mb-2">
                Marking Scheme / Preset
              </label>
              <select
                id="preset-selector"
                class="w-full h-10 rounded-sm border border-hairline bg-canvas px-3 text-sm text-ink focus:outline-none focus:ring-1 focus:ring-primary appearance-none cursor-pointer"
              >
                <option value="mu-engg">Mumbai University Engineering (80 Theory + 20 Internals, 40% Pass)</option>
                <option value="mu-degree">Mumbai University B.Sc/B.Com (75 Theory + 25 Internals, 40% Pass)</option>
                <option value="autonomous">Autonomous College Scheme (30 IA-1 + 20 IA-2 + 20 MCQ + 60 ESE)</option>
                <option value="generic-60-40">Generic Degree Scheme (60 Theory + 40 Internals, 40% Pass)</option>
                <option value="std-100-40">Standard 100 Marks (No Internals, 40% Pass)</option>
                <option value="std-100-35">Standard 100 Marks (No Internals, 35% Pass)</option>
                <option value="custom">Custom Scheme (Define your own limits…)</option>
              </select>
            </div>

            <!-- Parameters Grid (Overall passing & Target) -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="overall-pass-percent" class="block text-xs text-ink mb-1.5 font-medium">Passing Threshold (%)</label>
                <input type="number" id="overall-pass-percent" value="40" min="0" max="100" class="w-full h-9 rounded-sm border border-hairline bg-canvas px-2.5 text-xs text-ink focus:outline-none" />
                <p class="text-[10px] text-mute mt-1 leading-normal">Combined minimum to pass the subject. e.g., 40% means ≥40/100 total.</p>
              </div>
              
              <div>
                <div class="flex items-center justify-between mb-1.5">
                  <label for="target-percent" class="text-xs font-medium text-ink">Target Percentage</label>
                  <span id="target-percent-val" class="text-[10px] font-mono text-mute font-semibold">60% (First Class)</span>
                </div>
                <div class="flex items-center gap-2">
                  <input
                    type="range"
                    id="target-percent-range"
                    min="35"
                    max="100"
                    value="60"
                    step="1"
                    class="h-1.5 flex-1 cursor-pointer appearance-none rounded-full bg-canvas-soft-2 accent-primary"
                    aria-label="Target percentage slider"
                  />
                  <input
                    type="number"
                    id="target-percent"
                    value="60"
                    min="35"
                    max="100"
                    inputmode="numeric"
                    autocomplete="off"
                    class="h-8 w-14 rounded-sm border border-hairline bg-canvas text-center text-xs font-semibold text-ink focus:outline-none"
                  />
                  <span class="font-mono text-xs text-mute font-semibold">%</span>
                </div>
              </div>
            </div>

            <!-- Predictor marks simulator slider -->
            <div class="border-t border-hairline pt-4">
              <div class="flex items-center justify-between mb-2">
                <label for="predictor-marks" class="text-sm font-medium text-ink flex items-center gap-1.5">
                  <span>Exam Predictor</span>
                  <span class="rounded-full bg-link-bg-soft border border-link/10 text-link px-2 py-0.5 font-mono text-[9px] font-bold uppercase">
                    Interactive
                  </span>
                </label>
                <span id="predictor-max-label" class="text-[11px] font-mono text-mute">out of 80</span>
              </div>
              <p class="text-xs text-mute mb-3 leading-normal">
                Drag this slider to simulate different scores in your target exam and see predicted outcomes.
              </p>

              <!-- Exam Predictor dynamic details panel -->
              <div class="rounded-sm border border-hairline bg-canvas-soft-2 p-3.5 mb-3 text-xs flex flex-col gap-2 font-mono">
                <div class="flex justify-between items-center">
                  <span class="text-mute font-sans">Target Exam:</span>
                  <span id="predict-exam-name" class="font-semibold text-ink font-sans">Theory Exam (ESE)</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-mute font-sans">Current Marks Obtained:</span>
                  <span id="predict-current-score" class="font-semibold text-ink">0 / 80</span>
                </div>
                <div class="flex justify-between items-center border-t border-hairline pt-2">
                  <span class="text-mute font-sans font-semibold text-link">Predicted Score:</span>
                  <span id="predict-val-label" class="font-bold text-link">40 / 80</span>
                </div>
              </div>

              <div class="flex items-center gap-4">
                <input
                  type="range"
                  id="predictor-marks-range"
                  min="0"
                  max="80"
                  value="40"
                  class="h-1.5 flex-1 cursor-pointer appearance-none rounded-full bg-canvas-soft-2 accent-primary"
                  aria-label="Predictor score slider"
                />
                <input
                  type="number"
                  id="predictor-marks"
                  value="40"
                  min="0"
                  max="80"
                  inputmode="numeric"
                  autocomplete="off"
                  class="h-9 w-20 rounded-sm border border-hairline bg-canvas text-center text-sm font-semibold text-ink focus:outline-none"
                />
              </div>
            </div>

          </div>
        </div>

        <!-- Dynamic Components Table Card -->
        <div class="rounded-md border border-hairline bg-canvas p-4 sm:p-6 shadow-level-2 transition-colors duration-200">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-sm font-semibold uppercase tracking-wider text-mute font-mono">
              Exam Components
            </h2>
            <span class="text-[10px] font-mono bg-canvas-soft-2 border border-hairline rounded-full px-2 py-0.5 text-mute">
              Adjust Marks
            </span>
          </div>
          <p class="text-xs text-mute mb-4 leading-normal">
            Configure each exam component below. Check the <b>Target Exam</b> radio button to designate the ESE or final theory exam you wish to predict.
          </p>

          <div class="overflow-x-auto -mx-4 sm:mx-0 mb-4">
            <table class="w-full border-collapse text-left text-xs min-w-[540px] sm:min-w-0">
              <thead>
                <tr class="border-b border-hairline bg-canvas-soft-2 font-mono text-[10px] uppercase text-mute">
                  <th class="py-2 px-3 font-semibold">Component</th>
                  <th class="py-2 px-3 font-semibold w-20 text-center">Max</th>
                  <th class="py-2 px-3 font-semibold w-20 text-center">Obtained</th>
                  <th class="py-2 px-3 font-semibold w-20 text-center">Min Pass %</th>
                  <th class="py-2 px-3 font-semibold w-20 text-center">Target</th>
                  <th class="py-2 px-3 font-semibold w-12 text-center">Del</th>
                </tr>
              </thead>
              <tbody id="components-rows" class="divide-y divide-hairline">
                <!-- Dynamic component rows -->
              </tbody>
            </table>
          </div>

          <button
            id="add-component-btn"
            class="h-9 w-full inline-flex items-center justify-center gap-2 rounded-sm border border-hairline bg-canvas text-xs font-semibold text-ink hover:bg-canvas-soft-2 transition-colors cursor-pointer"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M12 5v14m-7-7h14" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Add Exam Component
          </button>
        </div>

      </div>

      <!-- Calculation Outputs & Share Panel -->
      <div class="flex flex-col gap-6 lg:col-span-5">
        
        <!-- Live Calculations Card -->
        <div class="rounded-md border border-hairline bg-canvas p-4 sm:p-6 shadow-level-2 transition-colors duration-200">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-mute font-mono mb-6">
            Required Theory Score
          </h2>

          <!-- Main results -->
          <div class="flex flex-col items-center justify-center py-4 text-center">
            
            <div id="gauge-container" class="relative flex h-36 w-36 items-center justify-center rounded-full border-[10px] border-success/30 bg-canvas transition-colors duration-300">
              <div class="flex flex-col items-center">
                <span id="result-theory-needed" class="font-sans text-3xl font-bold tracking-tight tabular-nums text-ink">
                  32
                </span>
                <span id="result-theory-max" class="text-[10px] font-mono font-medium text-mute mt-0.5">OUT OF 80</span>
              </div>
              <span id="gauge-status-led" class="absolute top-2 right-2 h-3.5 w-3.5 rounded-full border-2 border-canvas shadow-sm bg-success transition-all duration-300"></span>
            </div>

            <p id="theory-advice" class="mt-5 text-sm leading-relaxed text-body font-medium px-4">
              You must score at least 32 marks in the theory exam to pass the course.
            </p>

            <!-- Warnings / Alert Banners -->
            <div id="internal-status-card" class="mt-6 w-full rounded-sm border p-3.5 flex items-start gap-3 text-left transition-all duration-300 bg-success/5 border-success/20">
              <div id="internal-status-icon" class="text-success mt-0.5">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="10" /><path d="m9 12 2 2 4-4" />
                </svg>
              </div>
              <div>
                <h4 id="internal-status-title" class="text-xs font-semibold uppercase tracking-wider text-success font-mono">
                  Internals Cleared
                </h4>
                <p id="internal-status-desc" class="text-xs text-body mt-1 leading-normal">
                  Your internal assessment score is above the passing minimum.
                </p>
              </div>
            </div>

            <!-- Target marks output -->
            <div class="mt-4 w-full rounded-sm border border-hairline bg-canvas-soft-2 p-3.5 text-left font-mono text-xs text-body leading-relaxed">
              <span class="block font-bold text-ink mb-1 uppercase text-[10px] text-mute">Target Score Simulator:</span>
              <span id="target-breakdown">To reach 60% overall, you need 45 marks in the theory paper.</span>
            </div>

            <!-- Predictor results breakdown -->
            <div class="mt-4 w-full rounded-sm border border-hairline bg-canvas-soft-2 p-3.5 text-left font-mono text-xs text-body leading-relaxed">
              <span class="block font-bold text-ink mb-1 uppercase text-[10px] text-mute">Score Predictor Results:</span>
              <span id="predictor-breakdown">Scoring 40 marks in ESE results in a final score of 70% (First Class).</span>
            </div>

          </div>
        </div>

        <!-- Share & Export Card -->
        <div class="rounded-md border border-hairline bg-canvas p-4 sm:p-6 shadow-level-2 transition-colors duration-200">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-mute font-mono mb-4">
            Share Results
          </h2>
          <p class="text-xs text-mute mb-4 leading-relaxed">
            Generate a copy-paste status card to share on student study groups.
          </p>

          <div class="rounded-sm border border-hairline bg-canvas-soft-2 p-3 font-mono text-[11px] text-body whitespace-pre-wrap select-all leading-normal" id="share-text-box">
            Loading results…
          </div>

          <button
            id="copy-share-btn"
            class="mt-4 w-full h-9 inline-flex items-center justify-center gap-2 rounded-sm bg-primary px-4 text-xs font-semibold text-on-primary hover:bg-ink/90 transition-colors cursor-pointer"
            aria-label="Copy pass marks results to clipboard"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
            </svg>
            <span id="copy-btn-text">Copy Results</span>
          </button>
          <span id="copy-status-live" role="status" aria-live="polite" class="sr-only"></span>
        </div>

      </div>
    </div>

    <!-- Detailed Guide Section -->
    <section class="py-16 mt-16 border-t border-hairline transition-colors duration-200">
      <div class="mx-auto max-w-4xl">
        <span class="font-mono text-[11px] uppercase tracking-wider text-mute block text-center mb-2">Detailed Guide</span>
        <h2 class="text-center font-sans text-2xl font-semibold tracking-tight text-ink md:text-3xl mb-12 animate-fade-in">
          Understanding College Passing Marks and Target Calculations
        </h2>

        <div class="prose prose-sm max-w-none text-body leading-relaxed space-y-8 font-sans">
          <div>
            <p>
              Preparing for college exams involves more than just studying; it requires planning. To optimize your study hours and reduce academic anxiety, you need to know exactly how many marks you must secure in your end-semester theory papers to pass. Furthermore, if you are aiming for a specific overall grade (like a First Class or Distinction), you need to know how much you must score based on your existing internal assessment marks.
            </p>
            <p class="mt-4">
              In most Indian universities, passing criteria are multi-layered. Simply adding your internals and end-semester scores is not enough due to separate passing regulations. This guide outlines how passing marks are calculated, how separate passing rules work in institutions like Mumbai University, and how to simulate targets effectively.
            </p>
          </div>

          <div>
            <h3 class="font-sans text-lg font-semibold tracking-tight text-ink mb-3">
              How College Passing Marks Are Calculated
            </h3>
            <p>
              To calculate the minimum theory marks you need to pass a course, you must apply both of the following rules:
            </p>
            <ol class="list-decimal list-inside space-y-2 mt-4 ml-2">
              <li>
                <strong class="text-ink">Independent Theory Minimum:</strong> The minimum score required in the theory exam alone. E.g. for an 80-mark theory paper with a 40% threshold, you must score at least 32 marks.
              </li>
              <li>
                <strong class="text-ink">Overall Combined Minimum:</strong> The total combined marks (Theory + Internals) needed to reach the overall passing percentage. E.g. for a combined 100 marks with a 40% overall threshold, you need at least 40 marks total.
              </li>
            </ol>
            <p class="mt-4">
              The mathematical formula to determine the marks needed in the theory paper is:
            </p>
            
            <div class="my-6 rounded-sm border border-hairline bg-canvas-soft-2 p-4 text-center font-mono text-sm text-ink leading-relaxed shadow-sm">
              Theory Marks Needed = Math.max(Theory Min Pass, Combined Pass Total - Internals Marks Obtained)
            </div>

            <p class="mt-4">
              This formula ensures that even if your high internal assessment score (e.g. 19/20) means you only need 21 marks to reach the overall 40-mark passing total, you are still restricted by the individual theory minimum (32 marks). You must hit 32 in the theory paper to pass the course.
            </p>
          </div>

          <div>
            <h3 class="font-sans text-lg font-semibold tracking-tight text-ink mb-3">
              Mumbai University Passing Rules (80:20 and 75:25 Patterns)
            </h3>
            <p>
              The University of Mumbai enforces strict "separate passing" criteria across its various programs:
            </p>

            <div class="space-y-6 mt-6">
              <div class="border-l-2 border-hairline pl-4">
                <h4 class="font-sans text-sm font-semibold text-ink">Engineering Programs (80:20 Pattern)</h4>
                <p class="text-xs text-body mt-1 leading-relaxed">
                  Engineering courses feature an 80-mark end-semester theory exam and a 20-mark internal assessment (term work/quizzes). The passing threshold is 40% for both heads independently. You must secure at least 32/80 in the theory paper and 8/20 in internals. Securing 40/80 in theory but only 6/20 in internals results in a fail status under the internal backlog head.
                </p>
              </div>

              <div class="border-l-2 border-hairline pl-4">
                <h4 class="font-sans text-sm font-semibold text-ink">Degree Programs (75:25 Pattern)</h4>
                <p class="text-xs text-body mt-1 leading-relaxed">
                  B.Sc, B.Com, and B.A. degree courses under the CBCS scheme often use a 75-mark end-semester theory exam and a 25-mark internal evaluation. The passing threshold is 40% separately. This requires a minimum of 30/75 in the theory paper and 10/25 in internal marks.
                </p>
              </div>
            </div>
          </div>

          <div>
            <h3 class="font-sans text-lg font-semibold tracking-tight text-ink mb-3">
              Understanding Separate Passing in Engineering and Degrees
            </h3>
            <p>
              The rationale behind separate passing is to prevent students from bypassing theory preparation by accumulating maximum internal marks, or vice-versa. Because college faculty grade internal assignments, term work, and presentations locally, there is a risk of grade inflation. Enforcing an independent 40% threshold on the university-conducted end-semester theory paper maintains academic integrity and ensures that all students demonstrate a baseline level of understanding under controlled exam conditions.
            </p>
            <p class="mt-4">
              If you fall short of the internal passing minimum (e.g. scoring 6 out of 20), you are ineligible to clear the subject, even if you write a perfect theory paper. You will have to submit supplementary assignments, repeat term work, or clear a backlog fee to update your internal records in the subsequent term.
            </p>
          </div>

          <div>
            <h3 class="font-sans text-lg font-semibold tracking-tight text-ink mb-3">
              Simulating Marks to Reach a Target Grade
            </h3>
            <p>
              If your academic goal is not just passing but achieving a specific grade bracket, you must plan your end-semester prep accordingly. For instance, in Mumbai University, degree classifications are awarded as follows:
            </p>
            <ul class="list-disc list-inside space-y-2 mt-4 ml-2">
              <li><strong class="text-ink">First Class with Distinction:</strong> 70% and above</li>
              <li><strong class="text-ink">First Class:</strong> 60% to 69.99%</li>
              <li><strong class="text-ink">Second Class:</strong> 50% to 59.99%</li>
            </ul>
            <p class="mt-4">
              To calculate what you must score in theory to reach these targets, subtract your internal marks from the target total marks:
            </p>
            <div class="my-4 rounded-sm border border-hairline bg-canvas-soft-2 p-3 font-mono text-xs text-ink leading-relaxed pl-6">
              Theory Score for Target = Combined Target Marks - Internals Marks Obtained
            </div>
            <p class="mt-4">
              Our built-in **Target Grade Simulator** computes this value dynamically. If your internal assessment score is low, you will see a warning indicating if your target requires more marks than the theory paper conducts (e.g., needing 85 marks on an 80-mark paper). This helps you set realistic targets or allocate study time to other subjects where a higher grade is still mathematically achievable.
            </p>
          </div>
        </div>

        <!-- Related Utilities Grid -->
        <div class="mt-16 border-t border-hairline pt-12">
          <h3 class="font-sans text-lg font-semibold tracking-tight text-ink mb-6">
            Explore More Academic Utilities
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a href="/attendance-calculator" class="group rounded-md border border-hairline bg-canvas p-5 hover:border-ink transition-all shadow-sm hover:shadow-md">
              <h4 class="font-sans text-sm font-semibold text-ink group-hover:text-primary transition-colors flex items-center justify-between">
                <span>Attendance & Bunk Tracker</span>
                <svg class="h-4 w-4 text-mute group-hover:text-ink transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M5 12h14m-7-7 7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </h4>
              <p class="text-xs text-body mt-2 leading-relaxed">
                Calculate if you can skip today's lectures or find exactly how many classes you must attend to maintain 75% attendance.
              </p>
            </a>

            <a href="/gpa-calculator" class="group rounded-md border border-hairline bg-canvas p-5 hover:border-ink transition-all shadow-sm hover:shadow-md">
              <h4 class="font-sans text-sm font-semibold text-ink group-hover:text-primary transition-colors flex items-center justify-between">
                <span>GPA Calculator</span>
                <svg class="h-4 w-4 text-mute group-hover:text-ink transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M5 12h14m-7-7 7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </h4>
              <p class="text-xs text-body mt-2 leading-relaxed">
                Compute semester-wise SGPA and overall CGPA using credit-weighted grades. Plan grades needed for target score.
              </p>
            </a>

            <a href="/cgpa-to-percentage" class="group rounded-md border border-hairline bg-canvas p-5 hover:border-ink transition-all shadow-sm hover:shadow-md">
              <h4 class="font-sans text-sm font-semibold text-ink group-hover:text-primary transition-colors flex items-center justify-between">
                <span>CGPA Calculator</span>
                <svg class="h-4 w-4 text-mute group-hover:text-ink transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M5 12h14m-7-7 7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </h4>
              <p class="text-xs text-body mt-2 leading-relaxed">
                Convert 10-point scale CGPA/CGPI to equivalent marks percentage instantly using official university formulas.
              </p>
            </a>

            <a href="/atkt-eligibility-helper" class="group rounded-md border border-hairline bg-canvas p-5 hover:border-ink transition-all shadow-sm hover:shadow-md">
              <h4 class="font-sans text-sm font-semibold text-ink group-hover:text-primary transition-colors flex items-center justify-between">
                <span>ATKT Helper</span>
                <svg class="h-4 w-4 text-mute group-hover:text-ink transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M5 12h14m-7-7 7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </h4>
              <p class="text-xs text-body mt-2 leading-relaxed">
                Understand university rules for backlogs, Allowed to Keep Terms (ATKT) eligibility, and academic promotions.
              </p>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-16 mt-16 border-t border-hairline transition-colors duration-200">
      <div class="mx-auto max-w-4xl">
        <h2 class="text-center font-sans text-2xl font-semibold tracking-tight text-ink md:text-3xl">
          Exam Passing FAQ
        </h2>
        <p class="text-center mt-2 text-sm text-body">
          Clarifying key doubts about university passing scores, internal limits, and target marks.
        </p>

        <div class="mt-10 divide-y divide-hairline border-t border-b border-hairline bg-canvas px-6 rounded-md border">
          {faq.map((item) => (
            <div class="py-4">
              <details class="group [&_summary::-webkit-details-marker]:hidden">
                <summary class="flex cursor-pointer items-center justify-between gap-1.5 text-base font-medium text-ink focus:outline-none select-none">
                  <span>{item.question}</span>
                  <span class="relative h-5 w-5 shrink-0">
                    <svg
                      class="absolute inset-0 h-5 w-5 opacity-100 group-open:opacity-0 transition-opacity duration-200"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      viewBox="0 0 24 24"
                    >
                      <path d="M12 5v14m-7-7h14" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <svg
                      class="absolute inset-0 h-5 w-5 opacity-0 group-open:opacity-100 transition-opacity duration-200"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      viewBox="0 0 24 24"
                    >
                      <path d="M5 12h14" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                </summary>
                <p class="mt-3 text-sm leading-relaxed text-body animate-fade-in">
                  {item.answer}
                </p>
              </details>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  import { SITE_URL } from '../config';

  interface Component {
    name: string;
    max: number;
    scored: number;
    passPercent: number;
    isTarget: boolean;
  }

  // DOM element bindings
  const presetSelector = document.getElementById('preset-selector') as HTMLSelectElement | null;
  const componentsRowsContainer = document.getElementById('components-rows');
  const addComponentBtn = document.getElementById('add-component-btn');

  const overallPassPercentInput = document.getElementById('overall-pass-percent') as HTMLInputElement | null;

  const targetPercentInput = document.getElementById('target-percent') as HTMLInputElement | null;
  const targetPercentSlider = document.getElementById('target-percent-range') as HTMLInputElement | null;
  const targetPercentValLabel = document.getElementById('target-percent-val');

  const predictorInput = document.getElementById('predictor-marks') as HTMLInputElement | null;
  const predictorSlider = document.getElementById('predictor-marks-range') as HTMLInputElement | null;
  const predictorMaxLabel = document.getElementById('predictor-max-label');

  // Exam Predictor Details Bindings
  const predictExamName = document.getElementById('predict-exam-name');
  const predictCurrentScore = document.getElementById('predict-current-score');
  const predictValLabel = document.getElementById('predict-val-label');

  // Outputs
  const resultTheoryNeeded = document.getElementById('result-theory-needed');
  const resultTheoryMax = document.getElementById('result-theory-max');
  const theoryAdvice = document.getElementById('theory-advice');

  const internalStatusCard = document.getElementById('internal-status-card');
  const internalStatusIcon = document.getElementById('internal-status-icon');
  const internalStatusTitle = document.getElementById('internal-status-title');
  const internalStatusDesc = document.getElementById('internal-status-desc');

  const targetBreakdown = document.getElementById('target-breakdown');
  const predictorBreakdown = document.getElementById('predictor-breakdown');
  const shareTextBox = document.getElementById('share-text-box');
  const copyShareBtn = document.getElementById('copy-share-btn');
  const copyBtnText = document.getElementById('copy-btn-text');
  const gaugeContainer = document.getElementById('gauge-container');
  const gaugeStatusLed = document.getElementById('gauge-status-led');

  // Local state
  let components: Component[] = [];
  let isApplyingPreset = false;

  // Default presets
  const presets: Record<string, { components: Component[], overallPass: number }> = {
    'mu-engg': {
      overallPass: 40,
      components: [
        { name: 'Internal Assessment', max: 20, scored: 15, passPercent: 40, isTarget: false },
        { name: 'Theory Exam (ESE)', max: 80, scored: 32, passPercent: 40, isTarget: true }
      ]
    },
    'mu-degree': {
      overallPass: 40,
      components: [
        { name: 'Internal Assessment', max: 25, scored: 18, passPercent: 40, isTarget: false },
        { name: 'Theory Exam (ESE)', max: 75, scored: 30, passPercent: 40, isTarget: true }
      ]
    },
    'autonomous': {
      overallPass: 40,
      components: [
        { name: 'IA-1', max: 30, scored: 22, passPercent: 0, isTarget: false },
        { name: 'IA-2', max: 20, scored: 15, passPercent: 0, isTarget: false },
        { name: 'FA MCQ', max: 20, scored: 18, passPercent: 0, isTarget: false },
        { name: 'End Sem Exam (ESE)', max: 60, scored: 24, passPercent: 40, isTarget: true }
      ]
    },
    'generic-60-40': {
      overallPass: 40,
      components: [
        { name: 'Internals', max: 40, scored: 25, passPercent: 40, isTarget: false },
        { name: 'Theory Exam (ESE)', max: 60, scored: 24, passPercent: 40, isTarget: true }
      ]
    },
    'std-100-40': {
      overallPass: 40,
      components: [
        { name: 'Theory Exam (ESE)', max: 100, scored: 40, passPercent: 40, isTarget: true }
      ]
    },
    'std-100-35': {
      overallPass: 35,
      components: [
        { name: 'Theory Exam (ESE)', max: 100, scored: 35, passPercent: 35, isTarget: true }
      ]
    }
  };

  // Double binding range sliders to inputs
  const syncRangeInput = (slider: HTMLInputElement | null, numInput: HTMLInputElement | null, updateCallback: () => void) => {
    if (slider && numInput) {
      slider.addEventListener('input', () => {
        numInput.value = slider.value;
        updateCallback();
      });
      numInput.addEventListener('input', () => {
        let val = parseInt(numInput.value);
        if (isNaN(val)) val = 0;
        const min = parseInt(slider.min);
        const max = parseInt(slider.max);
        slider.value = Math.max(min, Math.min(max, val)).toString();
        updateCallback();
      });
    }
  };

  const handlePresetChange = () => {
    if (!presetSelector) return;
    const preset = presetSelector.value;
    if (preset === 'custom') return;

    const data = presets[preset];
    if (data) {
      isApplyingPreset = true;
      if (overallPassPercentInput) {
        overallPassPercentInput.value = data.overallPass.toString();
      }
      // Deep clone preset components
      components = data.components.map(c => ({ ...c }));
      
      // Sync predictor slider to target component's default score
      const targetComp = components.find(c => c.isTarget);
      if (targetComp && predictorSlider && predictorInput) {
        predictorSlider.max = targetComp.max.toString();
        predictorInput.max = targetComp.max.toString();
        predictorSlider.value = targetComp.scored.toString();
        predictorInput.value = targetComp.scored.toString();
      }

      isApplyingPreset = false;
      renderComponents();
      calculate();
    }
  };

  const renderComponents = () => {
    if (!componentsRowsContainer) return;
    componentsRowsContainer.innerHTML = '';

    components.forEach((comp, idx) => {
      const tr = document.createElement('tr');
      tr.className = "hover:bg-canvas-soft transition-colors font-mono text-xs";
      tr.innerHTML = `
        <td class="py-2.5 px-3">
          <input
            type="text"
            value="${comp.name}"
            class="w-full h-8 rounded-sm border border-hairline bg-canvas px-2 text-xs text-ink focus:outline-none comp-name-input font-sans"
            data-index="${idx}"
            aria-label="Component Name"
          />
        </td>
        <td class="py-2.5 px-3 text-center">
          <input
            type="number"
            value="${comp.max}"
            min="1"
            class="w-full h-8 rounded-sm border border-hairline bg-canvas text-center text-xs font-semibold text-ink focus:outline-none comp-max-input"
            data-index="${idx}"
            aria-label="Max Marks"
          />
        </td>
        <td class="py-2.5 px-3 text-center">
          <input
            type="number"
            value="${comp.scored}"
            min="0"
            max="${comp.max}"
            class="w-full h-8 rounded-sm border border-hairline bg-canvas text-center text-xs font-semibold text-ink focus:outline-none comp-scored-input"
            data-index="${idx}"
            aria-label="Marks Obtained"
          />
        </td>
        <td class="py-2.5 px-3 text-center">
          <input
            type="number"
            value="${comp.passPercent}"
            min="0"
            max="100"
            class="w-full h-8 rounded-sm border border-hairline bg-canvas text-center text-xs font-semibold text-ink focus:outline-none comp-pass-input"
            data-index="${idx}"
            aria-label="Min Pass %"
          />
        </td>
        <td class="py-2.5 px-3 text-center">
          <input
            type="radio"
            name="sim-target-radio"
            class="h-4 w-4 accent-primary cursor-pointer comp-target-radio"
            data-index="${idx}"
            ${comp.isTarget ? 'checked' : ''}
            aria-label="Designate as simulated target"
          />
        </td>
        <td class="py-2.5 px-3 text-center">
          <button
            class="h-7 w-7 inline-flex items-center justify-center rounded-sm border border-hairline text-mute hover:text-error hover:bg-error/5 hover:border-error/20 transition-colors delete-comp-btn cursor-pointer"
            data-index="${idx}"
            ${components.length <= 1 ? 'disabled' : ''}
            aria-label="Delete component"
          >
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </td>
      `;
      componentsRowsContainer.appendChild(tr);
    });

    // Attach row event listeners
    document.querySelectorAll('.comp-name-input').forEach(input => {
      input.addEventListener('input', (e) => {
        const index = parseInt((e.target as HTMLInputElement).dataset.index || '0');
        components[index].name = (e.target as HTMLInputElement).value;
        setPresetCustom();
        calculate();
      });
    });

    document.querySelectorAll('.comp-max-input').forEach(input => {
      input.addEventListener('input', (e) => {
        const index = parseInt((e.target as HTMLInputElement).dataset.index || '0');
        let val = parseInt((e.target as HTMLInputElement).value);
        if (isNaN(val) || val <= 0) val = 100;
        components[index].max = val;
        
        // Adjust scored boundary if needed
        if (components[index].scored > val) {
          components[index].scored = val;
        }

        setPresetCustom();
        
        // Re-render to update inputs boundaries (e.g. scored max)
        renderComponents();
        calculate();
      });
    });

    document.querySelectorAll('.comp-scored-input').forEach(input => {
      input.addEventListener('input', (e) => {
        const index = parseInt((e.target as HTMLInputElement).dataset.index || '0');
        let val = parseInt((e.target as HTMLInputElement).value);
        if (isNaN(val) || val < 0) val = 0;
        if (val > components[index].max) val = components[index].max;
        components[index].scored = val;

        // If this component is the simulated target, sync it to the predictor slider
        if (components[index].isTarget && predictorSlider && predictorInput) {
          predictorSlider.value = val.toString();
          predictorInput.value = val.toString();
        }

        setPresetCustom();
        calculate();
      });
    });

    document.querySelectorAll('.comp-pass-input').forEach(input => {
      input.addEventListener('input', (e) => {
        const index = parseInt((e.target as HTMLInputElement).dataset.index || '0');
        let val = parseInt((e.target as HTMLInputElement).value);
        if (isNaN(val) || val < 0) val = 0;
        if (val > 100) val = 100;
        components[index].passPercent = val;

        setPresetCustom();
        calculate();
      });
    });

    document.querySelectorAll('.comp-target-radio').forEach(radio => {
      radio.addEventListener('change', (e) => {
        const index = parseInt((e.target as HTMLInputElement).dataset.index || '0');
        components.forEach((c, idx) => {
          c.isTarget = (idx === index);
        });

        // Sync predictor slider to the newly selected target component's score
        const targetComp = components[index];
        if (targetComp && predictorSlider && predictorInput) {
          predictorSlider.max = targetComp.max.toString();
          predictorInput.max = targetComp.max.toString();
          predictorSlider.value = targetComp.scored.toString();
          predictorInput.value = targetComp.scored.toString();
        }

        setPresetCustom();
        renderComponents();
        calculate();
      });
    });

    document.querySelectorAll('.delete-comp-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const index = parseInt((e.currentTarget as HTMLButtonElement).dataset.index || '0');
        if (components.length <= 1) return;
        const wasTarget = components[index].isTarget;
        components.splice(index, 1);
        
        // Ensure at least one target exists if the deleted one was target
        if (wasTarget && components.length > 0) {
          components[0].isTarget = true;
          
          // Sync predictor slider to new target
          const targetComp = components[0];
          if (targetComp && predictorSlider && predictorInput) {
            predictorSlider.max = targetComp.max.toString();
            predictorInput.max = targetComp.max.toString();
            predictorSlider.value = targetComp.scored.toString();
            predictorInput.value = targetComp.scored.toString();
          }
        }

        setPresetCustom();
        renderComponents();
        calculate();
      });
    });
  };

  const setPresetCustom = () => {
    if (isApplyingPreset) return;
    if (presetSelector) presetSelector.value = 'custom';
  };

  const calculate = () => {
    // Basic calculation parameters
    let overallPassPercent = 40;
    if (overallPassPercentInput) {
      overallPassPercent = parseInt(overallPassPercentInput.value);
      if (isNaN(overallPassPercent) || overallPassPercent < 0) overallPassPercent = 40;
      if (overallPassPercent > 100) overallPassPercent = 100;
    }

    let desiredPercent = 60;
    if (targetPercentInput) {
      desiredPercent = parseInt(targetPercentInput.value);
      if (isNaN(desiredPercent) || desiredPercent < 0) desiredPercent = 60;
      if (desiredPercent > 100) desiredPercent = 100;
      // Desired percent cannot be below overall passing percent
      if (desiredPercent < overallPassPercent) {
        desiredPercent = overallPassPercent;
        targetPercentInput.value = overallPassPercent.toString();
        if (targetPercentSlider) targetPercentSlider.value = overallPassPercent.toString();
      }
    }

    // Identify target component (simulated exam)
    const targetIndex = components.findIndex(c => c.isTarget);
    if (targetIndex === -1) {
      if (theoryAdvice) theoryAdvice.textContent = "Please select a Target Exam component.";
      return;
    }
    const targetComp = components[targetIndex];

    // Total Max Marks and Total Scored Non-target components
    let totalMax = 0;
    let totalScored = 0;
    let hasShortage = false;
    let shortageMsg = "";

    components.forEach((c) => {
      totalMax += c.max;
      if (!c.isTarget) {
        totalScored += c.scored;
        
        // Check separate passing rule for non-target component
        const minPassMarks = Math.ceil(c.max * (c.passPercent / 100));
        if (c.scored < minPassMarks) {
          hasShortage = true;
          shortageMsg += `${c.name} Shortage (${c.scored}/${c.max}, minimum ${minPassMarks} required). `;
        }
      }
    });

    // Sync Predictor Slider Max Limit
    if (predictorSlider && predictorInput) {
      predictorSlider.max = targetComp.max.toString();
      predictorInput.max = targetComp.max.toString();
      if (parseInt(predictorSlider.value) > targetComp.max) {
        predictorSlider.value = targetComp.max.toString();
        predictorInput.value = targetComp.max.toString();
      }
      if (predictorMaxLabel) {
        predictorMaxLabel.textContent = `out of ${targetComp.max}`;
      }
    }

    // Overall Passing Marks needed
    const overallPassTotal = Math.ceil(totalMax * (overallPassPercent / 100));

    // Target Component Pass Thresholds
    const targetMinPass = Math.ceil(targetComp.max * (targetComp.passPercent / 100));
    const targetOverallNeeded = overallPassTotal - totalScored;

    // Minimum marks needed in ESE / Simulated Target Component to Pass the Course
    const targetPassNeeded = Math.max(targetMinPass, targetOverallNeeded);

    // Update Theory Needed Displays
    if (resultTheoryNeeded) {
      if (hasShortage) {
        resultTheoryNeeded.textContent = "Fail";
      } else if (targetPassNeeded > targetComp.max) {
        resultTheoryNeeded.textContent = "N/A";
      } else if (targetComp.scored >= targetPassNeeded) {
        resultTheoryNeeded.textContent = targetComp.scored.toString();
      } else {
        resultTheoryNeeded.textContent = Math.max(0, targetPassNeeded).toString();
      }
    }

    if (resultTheoryMax) {
      resultTheoryMax.textContent = `OUT OF ${targetComp.max}`;
    }

    // Update Advice Text
    if (theoryAdvice) {
      if (hasShortage) {
        theoryAdvice.innerHTML = `<span class="text-error font-semibold font-sans">You cannot pass this subject</span> because of a backlog/shortage in one of your other exam components.`;
      } else if (targetPassNeeded > targetComp.max) {
        theoryAdvice.innerHTML = `<span class="text-error font-semibold font-sans">Mathematically Impossible to Pass.</span> Even a perfect score of ${targetComp.max}/${targetComp.max} in ${targetComp.name} won't reach the overall pass mark (${overallPassTotal}/${totalMax} total).`;
      } else {
        const needed = Math.max(0, targetPassNeeded);
        const currentScore = targetComp.scored;
        const diff = currentScore - needed;
        
        let diffClass = '';
        let diffText = '';
        let statusClass = '';
        let statusText = '';
        
        if (diff > 0) {
          diffText = `+${diff} marks above passing`;
          diffClass = 'text-success';
          statusText = 'PASS';
          statusClass = 'bg-success/10 text-success border border-success/20';
        } else if (diff === 0) {
          diffText = 'On passing threshold';
          diffClass = 'text-ink';
          statusText = 'PASS';
          statusClass = 'bg-success/10 text-success border border-success/20';
        } else {
          diffText = `${Math.abs(diff)} marks short`;
          diffClass = 'text-error';
          statusText = 'FAIL';
          statusClass = 'bg-error/10 text-error border border-error/20';
        }

        theoryAdvice.innerHTML = `
          <div class="w-full mt-4 border border-hairline rounded-sm p-3.5 bg-canvas-soft-2 text-left font-mono text-xs text-body flex flex-col gap-2 shadow-sm animate-fade-in">
            <div class="flex justify-between items-center">
              <span class="text-mute font-sans">Minimum Required:</span>
              <span class="font-bold text-ink">${needed} / ${targetComp.max}</span>
            </div>
            <div class="flex justify-between items-center border-t border-hairline pt-2">
              <span class="text-mute font-sans">Current ${targetComp.name}:</span>
              <span class="font-bold text-ink">${currentScore} / ${targetComp.max}</span>
            </div>
            <div class="flex justify-between items-center border-t border-hairline pt-2">
              <span class="text-mute font-sans">Difference:</span>
              <span class="font-bold ${diffClass}">${diffText}</span>
            </div>
            <div class="flex justify-between items-center border-t border-hairline pt-2">
              <span class="text-mute font-sans font-semibold">Status:</span>
              <span class="font-bold px-2.5 py-0.5 rounded-full text-[10px] uppercase tracking-wider ${statusClass}">${statusText}</span>
            </div>
          </div>
        `;
      }
    }

    // Update Status Card
    if (internalStatusCard && internalStatusIcon && internalStatusTitle && internalStatusDesc) {
      // Set Card styles based on shortage status
      internalStatusCard.className = "mt-6 w-full rounded-sm border p-3.5 flex items-start gap-3 text-left transition-all duration-300";
      
      if (hasShortage) {
        internalStatusCard.classList.add('bg-error/5', 'border-error/20');
        internalStatusTitle.textContent = "Component Shortage!";
        internalStatusTitle.className = "text-xs font-semibold uppercase tracking-wider text-error font-mono";
        internalStatusIcon.className = "text-error mt-0.5";
        internalStatusIcon.innerHTML = `<svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`;
        internalStatusDesc.textContent = shortageMsg;
      } else {
        internalStatusCard.classList.add('bg-success/5', 'border-success/20');
        internalStatusTitle.textContent = "Assessments Cleared";
        internalStatusTitle.className = "text-xs font-semibold uppercase tracking-wider text-success font-mono";
        internalStatusIcon.className = "text-success mt-0.5";
        internalStatusIcon.innerHTML = `<svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>`;
        
        let clearingInfo = "All continuous assessments are above their respective passing thresholds.";
        if (components.length <= 1) {
          clearingInfo = "No internal/continuous assessments configured. Scoring is 100% ESE-dependent.";
        }
        internalStatusDesc.textContent = clearingInfo;
      }
    }

    // Target Breakdown (Desired Final Percentage)
    const desiredPassTotal = Math.ceil(totalMax * (desiredPercent / 100));
    const targetDesiredNeeded = desiredPassTotal - totalScored;

    if (targetBreakdown) {
      if (hasShortage) {
        targetBreakdown.innerHTML = `Cannot compute target marks: Component shortage detected.`;
      } else if (targetDesiredNeeded > targetComp.max) {
        targetBreakdown.innerHTML = `To reach <span class="font-bold">${desiredPercent}%</span> overall: <span class="text-error font-semibold font-mono">Mathematically Impossible</span> (requires ${targetDesiredNeeded} marks in ${targetComp.name} but exam max is ${targetComp.max}).`;
      } else if (targetDesiredNeeded < targetPassNeeded) {
        const needed = Math.max(0, targetDesiredNeeded);
        targetBreakdown.innerHTML = `To reach <span class="font-bold">${desiredPercent}%</span> overall, you need <span class="font-bold">${needed} marks</span> — but the minimum passing threshold of <span class="font-bold">${targetPassNeeded} marks</span> in ${targetComp.name} takes precedence.`;
      } else {
        targetBreakdown.innerHTML = `To reach <span class="font-bold">${desiredPercent}%</span> overall, you must score <span class="font-bold">${targetDesiredNeeded} marks</span> in ${targetComp.name}.`;
      }
    }

    // Predictor Simulation Calculations
    let predictorScore = 0;
    if (predictorInput) {
      predictorScore = parseInt(predictorInput.value);
      if (isNaN(predictorScore)) predictorScore = 0;
      if (predictorScore > targetComp.max) {
        predictorScore = targetComp.max;
        predictorInput.value = targetComp.max.toString();
        if (predictorSlider) predictorSlider.value = targetComp.max.toString();
      }
    }

    const predictedTotalScored = totalScored + predictorScore;
    const predictedPercent = totalMax > 0 ? (predictedTotalScored / totalMax) * 100 : 0;
    
    // Check if predictor is a PASS
    const isPredictorPass = !hasShortage && (predictorScore >= targetMinPass) && (predictedPercent >= overallPassPercent);

    let gradeLabel = 'Fail';
    let ledColor = 'bg-error';
    let gaugeBorder = 'border-error/30';

    if (isPredictorPass) {
      ledColor = 'bg-success';
      gaugeBorder = 'border-success/30';
      if (predictedPercent >= 70) gradeLabel = 'First Class with Distinction';
      else if (predictedPercent >= 60) gradeLabel = 'First Class';
      else if (predictedPercent >= 50) gradeLabel = 'Second Class';
      else gradeLabel = 'Pass Class';
    }

    // Update Exam Predictor Card text labels
    if (predictExamName) predictExamName.textContent = targetComp.name;
    if (predictCurrentScore) predictCurrentScore.textContent = `${targetComp.scored} / ${targetComp.max}`;
    if (predictValLabel) predictValLabel.textContent = `${predictorScore} / ${targetComp.max}`;

    // Update Predictor Output Markup
    if (predictorBreakdown) {
      let statusSpan = isPredictorPass 
        ? `<span class="px-2 py-0.5 rounded-full font-semibold bg-success/15 text-success">PASS</span>` 
        : `<span class="px-2 py-0.5 rounded-full font-semibold bg-error/15 text-error">FAIL</span>`;
        
      predictorBreakdown.innerHTML = `
        <div class="flex flex-col gap-2 font-mono text-xs text-body leading-normal">
          <div class="flex justify-between items-center">
            <span class="text-mute font-sans font-medium">Final Score:</span>
            <span class="font-bold text-ink">${predictedTotalScored} / ${totalMax} marks</span>
          </div>
          <div class="flex justify-between items-center border-t border-hairline pt-2">
            <span class="text-mute font-sans font-medium">Final Percentage:</span>
            <span class="font-bold text-ink">${predictedPercent.toFixed(1)}%</span>
          </div>
          <div class="flex justify-between items-center border-t border-hairline pt-2">
            <span class="text-mute font-sans font-medium">Predicted Class:</span>
            <span class="font-semibold text-ink">${gradeLabel}</span>
          </div>
          <div class="flex justify-between items-center border-t border-hairline pt-2">
            <span class="text-mute font-sans font-medium">Simulation Status:</span>
            <span>${statusSpan}</span>
          </div>
        </div>
      `;
    }

    // Visual gauge indicators
    if (gaugeContainer) {
      gaugeContainer.className = `relative flex h-36 w-36 items-center justify-center rounded-full bg-canvas transition-colors duration-300 border-[10px] ${gaugeBorder}`;
    }
    if (gaugeStatusLed) {
      gaugeStatusLed.className = `absolute top-2 right-2 h-3.5 w-3.5 rounded-full border-2 border-canvas shadow-sm transition-all duration-300 ${ledColor}`;
    }

    // Update Desired Target display label
    if (targetPercentValLabel) {
      let desiredGradeLabel = 'Pass Class';
      if (desiredPercent >= 70) desiredGradeLabel = 'First Class with Distinction';
      else if (desiredPercent >= 60) desiredGradeLabel = 'First Class';
      else if (desiredPercent >= 50) desiredGradeLabel = 'Second Class';
      targetPercentValLabel.textContent = `${desiredPercent}% (${desiredGradeLabel})`;
    }

    // Update share text
    if (shareTextBox && presetSelector) {
      const preset = presetSelector.value;
      let schemeName = 'Custom Course Scheme';
      if (preset === 'mu-engg') schemeName = 'Mumbai Univ Engineering (80:20)';
      if (preset === 'mu-degree') schemeName = 'Mumbai Univ Degree (75:25)';
      if (preset === 'autonomous') schemeName = 'Autonomous College Pattern (130m)';
      if (preset === 'generic-60-40') schemeName = 'Degree Scheme (60:40)';
      if (preset === 'std-100-40') schemeName = 'Standard Scheme (100 Marks)';

      let shareMsg = `📊 Exam Pass Marks Card\n`;
      shareMsg += `• Scheme: ${schemeName}\n`;
      
      // List components
      shareMsg += `• Component Scores:\n`;
      components.forEach(c => {
        if (!c.isTarget) {
          shareMsg += `  - ${c.name}: ${c.scored} / ${c.max}\n`;
        } else {
          shareMsg += `  - ${c.name} (Actual): ${c.scored} / ${c.max}\n`;
        }
      });

      // Target results
      if (hasShortage) {
        shareMsg += `• Status: ❌ FAIL (Component Shortage)\n`;
      } else {
        const passNeededStr = targetPassNeeded > targetComp.max ? 'Impossible' : `${Math.max(0, targetPassNeeded)} / ${targetComp.max}`;
        shareMsg += `• ${targetComp.name} Needed to Pass: ${passNeededStr}\n`;
        
        if (targetDesiredNeeded <= targetComp.max) {
          shareMsg += `• ${targetComp.name} for Target (${desiredPercent}%): ${Math.max(0, targetDesiredNeeded)} marks\n`;
        } else {
          shareMsg += `• Target (${desiredPercent}%): Impossible\n`;
        }
      }

      // Predictor result
      shareMsg += `• Predictor: Scoring ${predictorScore}/${targetComp.max} in ${targetComp.name} → ${predictedPercent.toFixed(1)}% (${gradeLabel}) - ${isPredictorPass ? 'PASS' : 'FAIL'}\n`;

      shareMsg += `\nCalculate yours at: ${SITE_URL}/marks-needed-to-pass`;
      shareTextBox.textContent = shareMsg;
    }
  };

  // Sync inputs
  syncRangeInput(targetPercentSlider, targetPercentInput, calculate);
  syncRangeInput(predictorSlider, predictorInput, calculate);

  // Hook preset selector change
  if (presetSelector) {
    presetSelector.addEventListener('change', handlePresetChange);
  }

  // Hook overall pass percent input
  if (overallPassPercentInput) {
    overallPassPercentInput.addEventListener('input', calculate);
  }

  // Add component btn logic
  if (addComponentBtn) {
    addComponentBtn.addEventListener('click', () => {
      components.push({
        name: `Component ${components.length + 1}`,
        max: 50,
        scored: 30,
        passPercent: 0,
        isTarget: false
      });
      setPresetCustom();
      renderComponents();
      calculate();
    });
  }

  // Copy share button logic
  if (copyShareBtn && shareTextBox && copyBtnText) {
    copyShareBtn.addEventListener('click', () => {
      const textToCopy = shareTextBox.textContent || '';
      navigator.clipboard.writeText(textToCopy).then(() => {
        copyBtnText.textContent = "Copied!";
        copyShareBtn.classList.remove('bg-primary');
        copyShareBtn.classList.add('bg-success');
        const liveRegion = document.getElementById('copy-status-live');
        if (liveRegion) liveRegion.textContent = 'Results copied to clipboard';

        setTimeout(() => {
          copyBtnText.textContent = "Copy Results";
          copyShareBtn.classList.remove('bg-success');
          copyShareBtn.classList.add('bg-primary');
          if (liveRegion) liveRegion.textContent = '';
        }, 2000);
      }).catch(err => {
        console.error("Copy failed", err);
      });
    });
  }

  // Initialize page on load with mu-engg or default
  if (presetSelector) {
    presetSelector.value = 'mu-engg';
    handlePresetChange();
  }
</script>
