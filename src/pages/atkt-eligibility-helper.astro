      if (autonomousPanel) autonomousPanel.classList.add('hidden');

      // Show the selected one
      if (scheme === 'mu-engg') {
        muEnggPanel.classList.remove('hidden');
      } else if (scheme === 'mu-degree') {
        muDegreePanel.classList.remove('hidden');
        updateDegreeLabels(target);
      } else if (scheme === 'mu-nep') {
        muNepPanel.classList.remove('hidden');
        updateNepSliderSettings();
      } else if (scheme === 'custom') {
        customPanel.classList.remove('hidden');
      } else if (scheme === 'autonomous') {
        if (autonomousPanel) autonomousPanel.classList.remove('hidden');
      }

      // Prior clearance panel is shown for Y2-Y3 (Sem 5) and Y3-Y4 (Sem 7) targets for non-NEP systems
      let showPrior = false;
      if (target !== 'y1-y2') {
        if (scheme === 'mu-engg' || scheme === 'mu-degree') {
          showPrior = true;
        } else if (scheme === 'custom') {
          showPrior = customReqPrior ? customReqPrior.checked : true;
        } else if (scheme === 'autonomous') {
          showPrior = autonomousReqPrior ? autonomousReqPrior.checked : true;
        }
      }

      if (showPrior) {
