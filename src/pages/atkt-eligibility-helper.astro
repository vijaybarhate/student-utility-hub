      } else if (target === 'y3-y4') {
        labelOddSem.textContent = "Failed Subjects in Semester 5";
        labelEvenSem.textContent = "Failed Subjects in Semester 6";
      }
    }

    // Set credits slider boundaries dynamically based on target year
    function updateNepSliderSettings() {
      const target = targetSelect.value;
      const settings = nepCreditsMapping[target] || { required: 32, max: 44 };

      creditsRange.max = settings.max;
      creditsNum.max = settings.max;
      creditsMaxVal.textContent = `/ ${settings.max}`;
      creditsRequiredBadge.textContent = `Requires Min ${settings.required}/${settings.max}`;

      // Reset value if it exceeds max
      if (parseInt(creditsRange.value) > settings.max || creditsRange.value === "32") {
        creditsRange.value = settings.required;
        creditsNum.value = settings.required;
      }
    }

    // Synchronize Credits Range Slider & Number Input
    creditsRange.addEventListener('input', () => {
      creditsNum.value = creditsRange.value;
      calculateStanding();
    });

    creditsNum.addEventListener('input', () => {
      let val = parseInt(creditsNum.value) || 0;
      const max = parseInt(creditsRange.max);
      if (val < 0) val = 0;
      if (val > max) val = max;
      creditsNum.value = val;
      creditsRange.value = val;
      calculateStanding();
    });

    // Scheme or Target changed
    schemeSelect.addEventListener('change', () => {
      updateSchemePanels();
      syncLoggerToCounters();
      calculateStanding();
    });

    targetSelect.addEventListener('change', () => {
      updateSchemePanels();
      updateDegreeLabels(targetSelect.value);
      updateNepSliderSettings();
      syncLoggerToCounters();
      calculateStanding();
    });

    // ─── Current Semester Status Logic ─────────────────────────────────────────
    function updateSemesterStatus() {
      const scheme = schemeSelect.value;
      const semNum = parseInt(currentSemSelect?.value || '5');
      const eseCount = parseInt(semFailedEse?.value || '0') || 0;
      const internalCount = parseInt(semFailedInternal?.value || '0') || 0;
      const totalHeads = eseCount + internalCount;

      // Show/hide card — only makes full sense for MU Engineering (heads of passing system)
      const isEngg = scheme === 'mu-engg' || scheme === 'custom';

      // --- Can Appear? ---
      // In MU, you can ALWAYS appear for the next semester's exams regardless of backlogs.
      // The only exception: if you have a Year Drop you cannot register for the year.
      // But appearing for an individual semester exam is always allowed.
      let canAppear = true;
      let appearNote = 'You can appear for exams regardless of KTs';

      // --- Can Get Promoted (year-on-year)? ---
      // Only relevant at even sems (end of year): Sem 2 → Y2, Sem 4 → Y3, Sem 6 → Y4
      const isEndOfYear = semNum % 2 === 0;
      let promoteStatus = 'ON TRACK';
      let promoteNote = 'No year drop risk yet';
      let promoteColor = 'text-success';

      if (isEngg) {
        if (!isEndOfYear) {
          // Mid-year — projection based on current semester failures
          if (totalHeads === 0) {
            promoteStatus = 'ON TRACK';
            promoteNote = 'No failures so far this semester';
            promoteColor = 'text-success';
          } else if (totalHeads <= 4) {
            promoteStatus = 'WATCH OUT';
            promoteNote = `${totalHeads} head${totalHeads > 1 ? 's' : ''} failed — manageable but track ESE limit`;
            promoteColor = 'text-warning-deep';
          } else if (totalHeads <= 8) {
            promoteStatus = 'AT RISK';
            promoteNote = `${totalHeads}/8 heads — approaching limit. Clear in KT cycle.`;
            promoteColor = 'text-error';
          } else {
            promoteStatus = 'YEAR DROP RISK';
            promoteNote = `${totalHeads} heads exceeds MU limit of 8. Year drop likely.`;
            promoteColor = 'text-error';
          }
        } else {
          // End of year — definitive check
          if (totalHeads <= 8 && eseCount <= 5) {
            if (totalHeads === 0) {
              promoteStatus = 'PROMOTED';
              promoteNote = 'All clear — eligible for regular promotion';
              promoteColor = 'text-success';
            } else {
              promoteStatus = 'ATKT ELIGIBLE';
              promoteNote = `${totalHeads} backlog${totalHeads > 1 ? 's' : ''} — promoted with KTs`;
              promoteColor = 'text-warning-deep';
            }
          } else {
            promoteStatus = 'YEAR DROP';
            promoteNote = eseCount > 5 ? `ESE limit exceeded (${eseCount}/5)` : `Total heads exceeded (${totalHeads}/8)`;
            promoteColor = 'text-error';
          }
        }
      } else {
        // For degree / NEP — simplified
        promoteStatus = 'CHECK MAIN PANEL';
        promoteNote = 'Use the Academic Standings Setup above';
        promoteColor = 'text-mute';
      }

      // --- Risk Level ---
      let riskLevel = 'LOW';
      let riskNote = 'Well within ATKT limits';
      let riskColor = 'text-success';

      if (isEngg) {
        if (totalHeads === 0) {
          riskLevel = 'NONE'; riskNote = 'No failures logged this semester'; riskColor = 'text-success';
        } else if (totalHeads <= 3 && eseCount <= 2) {
          riskLevel = 'LOW'; riskNote = 'Few backlogs — manageable in KT cycle'; riskColor = 'text-success';
        } else if (totalHeads <= 6 || eseCount <= 4) {
          riskLevel = 'MEDIUM'; riskNote = 'Moderate backlog load — plan your KT cycle'; riskColor = 'text-warning-deep';
        } else if (totalHeads <= 8 && eseCount <= 5) {
          riskLevel = 'HIGH'; riskNote = 'At the ATKT limit — one more fail = Year Drop'; riskColor = 'text-error';
        } else {
          riskLevel = 'CRITICAL'; riskNote = 'Exceeds MU limits — Year Drop territory'; riskColor = 'text-error';
        }
      } else {
        riskLevel = '—'; riskNote = 'Select MU Engineering for risk analysis'; riskColor = 'text-mute';
      }

      // Apply to DOM
      if (semAppearVal) { semAppearVal.textContent = canAppear ? 'YES' : 'NO'; semAppearVal.className = `text-base font-bold ${canAppear ? 'text-success' : 'text-error'}`; }
      if (semAppearNote) semAppearNote.textContent = appearNote;

      if (semPromoteVal) { semPromoteVal.textContent = promoteStatus; semPromoteVal.className = `text-base font-bold ${promoteColor}`; }
      if (semPromoteNote) semPromoteNote.textContent = promoteNote;

      if (semRiskVal) { semRiskVal.textContent = riskLevel; semRiskVal.className = `text-base font-bold ${riskColor}`; }
      if (semRiskNote) semRiskNote.textContent = riskNote;
    }

    // Wire Current Semester Status card
    [currentSemSelect, semFailedEse, semFailedInternal].forEach(el => {
      if (el) el.addEventListener('input', updateSemesterStatus);
    });
    if (currentSemSelect) {
      currentSemSelect.addEventListener('change', () => {
        syncLoggerToCounters();
        updateSemesterStatus();
      });
    }
    // Also re-run when scheme changes
    schemeSelect.addEventListener('change', () => {
      syncLoggerToCounters();
      updateSemesterStatus();
    });

    // Initial render
    updateSemesterStatus();

    // Inputs listener
    [
      failedEseInput, failedInternalInput,
      failedOddInput, failedEvenInput,
      priorClearYes, priorClearNo,
      customReqPrior, customMaxHeads, customMaxEse, customMinCredits,
      customInputHeads, customInputEse, customInputCredits, customInputTotalCredits,
      autonomousReqPrior, autonomousMaxHeads, autonomousMaxEse, autonomousMaxGolden,
      autonomousInputHeads, autonomousInputEse, autonomousInputGolden
    ].forEach(el => {
      if (el) el.addEventListener('input', () => {
        // If they manually edit counters, they are breaking the direct sync with logger list
        // but let's allow it, just recalculate standing
        calculateStanding();
      });
      if (el && (el.type === 'radio' || el.type === 'checkbox')) {
        el.addEventListener('change', () => {
          if (el === autonomousReqPrior || el === customReqPrior) {
            updateSchemePanels();
          }
          calculateStanding();
        });
      }
    });

    // Logger implementation
    addCourseBtn.addEventListener('click', () => {
      // Add row object to list
      const target = targetSelect.value;
      let defaultSem = '1';
      if (target === 'y2-y3') defaultSem = '3';
      if (target === 'y3-y4') defaultSem = '5';

      const newCourse = {
        id: 'c_' + Date.now() + Math.random().toString(36).slice(2, 6),
        name: `Backlog Subject ${loggedCourses.length + 1}`,
        sem: defaultSem,
        type: 'theory', // theory, internal, both
        status: 'pending'
      };

      loggedCourses.push(newCourse);
      renderLogger();
      syncLoggerToCounters();
      calculateStanding();
    });

    clearLoggerBtn.addEventListener('click', () => {
      loggedCourses = [];
      renderLogger();
      syncLoggerToCounters();
      calculateStanding();
    });

    function renderLogger() {
      // Toggle empty state
      if (loggedCourses.length === 0) {
        emptyLoggerRow.style.display = 'table-row';
        clearLoggerBtn.classList.add('hidden');
      } else {
        emptyLoggerRow.style.display = 'none';
        clearLoggerBtn.classList.remove('hidden');
      }

      // Remove previously appended course rows
      const rows = loggerRows.querySelectorAll('tr:not(#empty-logger-row)');
      rows.forEach(r => r.remove());

      // Render rows
      loggedCourses.forEach((course) => {
        const tr = document.createElement('tr');
        tr.id = course.id;
        tr.className = 'hover:bg-canvas-soft-2 transition-colors';

        // Set dynamic options based on target
        const target = targetSelect.value;
        const scheme = schemeSelect.value;
        let sems = ['1', '2'];
        if (scheme === 'autonomous' || scheme === 'custom') {
          sems = ['1', '2', '3', '4', '5', '6', '7', '8'];
        } else {
          if (target === 'y2-y3') sems = ['3', '4'];
          if (target === 'y3-y4') sems = ['5', '6'];
        }

        // If it's B.Sc degree, type is just "whole subject" but we can map "both" as subject
        const isDegree = schemeSelect.value === 'mu-degree';

        tr.innerHTML = `
          <td class="py-2 px-3">
            <input
              type="text"
              value="${course.name}"
              class="w-full bg-transparent border-none text-xs text-ink focus:outline-none font-medium focus:ring-0 p-0"
              data-field="name"
            />
          </td>
          <td class="py-2 px-3">
            <select class="w-full bg-transparent border-none text-xs text-ink focus:outline-none p-0 cursor-pointer" data-field="sem">
              ${sems.map(s => `<option value="${s}" ${course.sem === s ? 'selected' : ''}>Sem ${s}</option>`).join('')}
            </select>
          </td>
          <td class="py-2 px-3">
            <select class="w-full bg-transparent border-none text-xs text-ink focus:outline-none p-0 cursor-pointer" data-field="type">
              <option value="theory" ${course.type === 'theory' ? 'selected' : ''}>${isDegree ? 'Whole Subject' : 'Theory (ESE) Only'}</option>
              ${!isDegree ? `
                <option value="internal" ${course.type === 'internal' ? 'selected' : ''}>Internal Only</option>
                <option value="both" ${course.type === 'both' ? 'selected' : ''}>Both (Theory + Internal)</option>
              ` : ''}
            </select>
          </td>
          <td class="py-2 px-3">
            <select class="w-full bg-transparent border-none text-xs text-ink focus:outline-none p-0 cursor-pointer" data-field="status">
              <option value="pending" ${course.status === 'pending' ? 'selected' : ''}>Pending</option>
              <option value="cleared" ${course.status === 'cleared' ? 'selected' : ''}>Cleared</option>
            </select>
          </td>
          <td class="py-2 px-3 text-center">
            <button class="text-error hover:text-error-deep cursor-pointer p-1" data-action="delete" title="Remove Course">
              <svg class="h-4 w-4 inline" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </td>
        `;

        // Event Listeners for inline fields
        const nameInput = tr.querySelector('[data-field="name"]');
        nameInput.addEventListener('change', (e) => {
          course.name = e.target.value;
        });

        const semSelect = tr.querySelector('[data-field="sem"]');
        semSelect.addEventListener('change', (e) => {
          course.sem = e.target.value;
          syncLoggerToCounters();
          calculateStanding();
        });

        const typeSelect = tr.querySelector('[data-field="type"]');
        typeSelect.addEventListener('change', (e) => {
          course.type = e.target.value;
          syncLoggerToCounters();
          calculateStanding();
        });

        const statusSelect = tr.querySelector('[data-field="status"]');
        statusSelect.addEventListener('change', (e) => {
          course.status = e.target.value;
          syncLoggerToCounters();
          calculateStanding();
        });

        const deleteBtn = tr.querySelector('[data-action="delete"]');
        deleteBtn.addEventListener('click', () => {
          loggedCourses = loggedCourses.filter(c => c.id !== course.id);
          renderLogger();
          syncLoggerToCounters();
          calculateStanding();
        });

        loggerRows.appendChild(tr);
      });
    }

    // Sync values from subject logger to the active counters
    function syncLoggerToCounters() {
      const scheme = schemeSelect.value;
      const inputs = [
        failedEseInput,
        failedInternalInput,
        failedOddInput,
        failedEvenInput,
        customInputHeads,
        customInputEse,
        autonomousInputHeads,
        autonomousInputEse,
        autonomousInputGolden
      ];

      // Hide all sync notes by default
      if (enggSyncNote) enggSyncNote.classList.add('hidden');
      if (degreeSyncNote) degreeSyncNote.classList.add('hidden');
      if (customSyncNote) customSyncNote.classList.add('hidden');
      if (autonomousSyncNote) autonomousSyncNote.classList.add('hidden');

      if (loggedCourses.length === 0) {
        // Unlock inputs and reset to 0
        inputs.forEach(input => {
          if (input) {
            input.value = '0';
            input.removeAttribute('readonly');
            input.classList.remove('bg-canvas-soft-2', 'text-mute');
          }
        });
        if (semFailedEse) {
          semFailedEse.value = '0';
          semFailedEse.removeAttribute('readonly');
          semFailedEse.classList.remove('bg-canvas-soft-2', 'text-mute');
        }
        if (semFailedInternal) {
          semFailedInternal.value = '0';
          semFailedInternal.removeAttribute('readonly');
          semFailedInternal.classList.remove('bg-canvas-soft-2', 'text-mute');
        }
        return;
      }

      // Lock inputs and style them as synced/readonly
      inputs.forEach(input => {
        if (input) {
          input.setAttribute('readonly', 'true');
          input.classList.add('bg-canvas-soft-2', 'text-mute');
        }
      });
      if (semFailedEse) {
        semFailedEse.setAttribute('readonly', 'true');
        semFailedEse.classList.add('bg-canvas-soft-2', 'text-mute');
      }
      if (semFailedInternal) {
        semFailedInternal.setAttribute('readonly', 'true');
        semFailedInternal.classList.add('bg-canvas-soft-2', 'text-mute');
      }

      // Show active sync note
      if (scheme === 'mu-engg' && enggSyncNote) {
        enggSyncNote.classList.remove('hidden');
      } else if (scheme === 'mu-degree' && degreeSyncNote) {
        degreeSyncNote.classList.remove('hidden');
      } else if (scheme === 'custom' && customSyncNote) {
        customSyncNote.classList.remove('hidden');
      } else if (scheme === 'autonomous' && autonomousSyncNote) {
        autonomousSyncNote.classList.remove('hidden');
      }

      let eseCount = 0;
      let internalCount = 0;
      let oddCount = 0;
      let evenCount = 0;

      loggedCourses.forEach(c => {
        // Only count pending backlogs towards active failures
        if (c.status === 'cleared') return;

        const semNum = parseInt(c.sem);
        if (semNum % 2 !== 0) {
          oddCount += 1;
        } else {
          evenCount += 1;
        }

        if (c.type === 'theory') {
          eseCount += 1;
        } else if (c.type === 'internal') {
          internalCount += 1;
        } else if (c.type === 'both') {
          eseCount += 1;
          internalCount += 1;
        }
      });

      if (failedEseInput) failedEseInput.value = eseCount.toString();
      if (failedInternalInput) failedInternalInput.value = internalCount.toString();
      if (failedOddInput) failedOddInput.value = oddCount.toString();
      if (failedEvenInput) failedEvenInput.value = evenCount.toString();
      if (customInputHeads) customInputHeads.value = (eseCount + internalCount).toString();
      if (customInputEse) customInputEse.value = eseCount.toString();

      // For autonomous: separate current-year heads vs prior-year (Golden KT) heads
      // "Prior year" depends on the target semester selection
      const autoTarget = targetSelect.value;
      let autoCurrentHeads = 0;
      let autoCurrentEse = 0;
      let autoGoldenKTs = 0;
      loggedCourses.forEach(c => {
        if (c.status === 'cleared') return;
        const semNum = parseInt(c.sem);
        // Prior year: sems that are 2+ years earlier than current target
        // y1-y2: no prior sems; y2-y3: sems 1-2 are prior; y3-y4: sems 1-4 are prior
        let isPriorSem = false;
        if (autoTarget === 'y2-y3' && semNum <= 2) isPriorSem = true;
        if (autoTarget === 'y3-y4' && semNum <= 4) isPriorSem = true;

        if (isPriorSem) {
          autoGoldenKTs += (c.type === 'both') ? 2 : 1;
        } else {
          if (c.type === 'theory' || c.type === 'both') { autoCurrentEse++; autoCurrentHeads++; }
          if (c.type === 'internal' || c.type === 'both') autoCurrentHeads++;
        }
      });
      if (autonomousInputHeads) autonomousInputHeads.value = autoCurrentHeads.toString();
      if (autonomousInputEse) autonomousInputEse.value = autoCurrentEse.toString();
      if (autonomousInputGolden) autonomousInputGolden.value = autoGoldenKTs.toString();

      // Count fails for selected semester
      if (currentSemSelect && semFailedEse && semFailedInternal) {
        const selectedSem = currentSemSelect.value;
        let semEse = 0;
        let semInt = 0;
        loggedCourses.forEach(c => {
          // Only count pending backlogs
          if (c.status === 'cleared') return;
          if (c.sem === selectedSem) {
            if (c.type === 'theory' || c.type === 'both') semEse++;
            if (c.type === 'internal' || c.type === 'both') semInt++;
          }
        });
        semFailedEse.value = semEse.toString();
        semFailedInternal.value = semInt.toString();
      }

      // Programmatically calculate if prior years are clear from logged courses
      const target = targetSelect.value;
      if (loggedCourses.length > 0) {
        let hasPriorKT = false;
        loggedCourses.forEach(c => {
          if (c.status === 'cleared') return;
          const semNum = parseInt(c.sem);
          if (target === 'y2-y3' && semNum <= 2) {
            hasPriorKT = true;
          } else if (target === 'y3-y4' && semNum <= 4) {
            hasPriorKT = true;
          }
        });

        if (hasPriorKT) {
          if (priorClearNo) priorClearNo.checked = true;
          if (priorClearYes) priorClearYes.checked = false;
        } else {
          if (priorClearYes) priorClearYes.checked = true;
          if (priorClearNo) priorClearNo.checked = false;
        }

        // Disable prior clearance radio options to prevent manual overrides that conflict with logger
        if (priorClearYes) priorClearYes.disabled = true;
        if (priorClearNo) priorClearNo.disabled = true;
      } else {
        // Enable them if no courses are logged
        if (priorClearYes) priorClearYes.disabled = false;
        if (priorClearNo) priorClearNo.disabled = false;
      }
    }

    // MAIN RULES CALCULATOR & STATE BINDER
    function calculateStanding() {
      const scheme = schemeSelect.value;
      const target = targetSelect.value;
      const isPriorClear = priorClearYes.checked; // only relevant if priorClearancePanel is visible

      let isEligible = true;
      let statusType = 'eligible'; // eligible, warning, drop
      let statusMsg = 'ELIGIBLE FOR PROMOTION';
      let statusSubtitleText = 'ATKT CRITERIA MET';
      let adviceText = '';
      
      // Progression Checks list array
      const checks = [];

      if (scheme === 'mu-engg') {
        const failedEse = parseInt(failedEseInput.value) || 0;
        const failedInternal = parseInt(failedInternalInput.value) || 0;
        const totalHeads = failedEse + failedInternal;

        // Prior Year Clearance Check (Sem 5 and Sem 7 only)
        if (target !== 'y1-y2') {
          const priorYearLabel = target === 'y2-y3' ? 'First Year (Sem 1 & 2) Cleared' : 'First & Second Year (Sem 1-4) Cleared';
          if (isPriorClear) {
            checks.push({ label: priorYearLabel, passed: true, detail: '0 prior backlogs remaining' });
          } else {
            checks.push({ label: priorYearLabel, passed: false, detail: 'Outstanding backlogs in prior years trigger a year drop' });
            isEligible = false;
            statusType = 'drop';
          }
        }

        // Limit Checks (Max 8 total heads, max 5 theory/ESE heads)
        const eseOk = failedEse <= 5;
        const totalOk = totalHeads <= 8;

        checks.push({
          label: 'Failed Theory (ESE) limit (≤ 5)',
          passed: eseOk,
          detail: `${failedEse} / 5 failed papers`
        });

        checks.push({
          label: 'Total Failed Heads limit (≤ 8)',
          passed: totalOk,
          detail: `${totalHeads} / 8 total heads of passing`
        });

        if (!eseOk || !totalOk) {
          isEligible = false;
          statusType = 'drop';
        }

        // Gauge Rendering
        updateGauge('Failed Heads', totalHeads, 8, isEligible);

        // State evaluation
        if (isEligible) {
          if (totalHeads > 0) {
            statusType = 'warning';
            statusMsg = 'ELIGIBLE (WITH BACKLOGS)';
            statusSubtitleText = 'PROVISIONAL ATKT PROMOTION';
            adviceText = `You are eligible to keep terms, but you are carrying ${totalHeads} backlogs. Plan to attempt and clear these in the next winter/summer KT cycle to prevent credit clog or a Year Drop next year.`;
          } else {
            statusType = 'eligible';
            statusMsg = 'ELIGIBLE (CLEARED ALL)';
            statusSubtitleText = 'REGULAR YEAR PROMOTION';
            adviceText = 'Excellent! You have passed all exams and are fully eligible to proceed to the next year without any backlogs.';
          }
        } else {
          statusMsg = 'DETENTION / YEAR DROP';
          statusSubtitleText = 'ELIGIBILITY CRITERIA FAILED';
          if (!isPriorClear && target !== 'y1-y2') {
            adviceText = 'You face a Year Drop due to outstanding backlogs from earlier years. Under MU rules, you must pass all previous-year subjects to enter the next cycle. Focus exclusively on clearing those specific courses in the next exam cycle.';
          } else {
            adviceText = `You have exceeded the ATKT backlog limits (${failedEse}/5 ESE papers or ${totalHeads}/8 total heads). You will face a Year Drop. File for revaluation if you are close to passing, or prepare to write ATKT exams.`;
          }
        }

      } else if (scheme === 'mu-degree') {
        const oddFailed = parseInt(failedOddInput.value) || 0;
        const evenFailed = parseInt(failedEvenInput.value) || 0;
        const totalDegreeBacklogs = oddFailed + evenFailed;

        // Prior Year Clearance Check (Sem 5 and Sem 7 only)
        if (target !== 'y1-y2') {
          const priorYearLabel = target === 'y2-y3' ? 'First Year (Sem 1 & 2) Cleared' : 'First & Second Year (Sem 1-4) Cleared';
          if (isPriorClear) {
            checks.push({ label: priorYearLabel, passed: true, detail: '0 prior backlogs remaining' });
          } else {
            checks.push({ label: priorYearLabel, passed: false, detail: 'Must clear prior year to enter third/fourth year' });
            isEligible = false;
            statusType = 'drop';
          }
        }

        // Limit Checks: Max 2 failed subjects in odd sem, max 2 in even sem
        const oddOk = oddFailed <= 2;
        const evenOk = evenFailed <= 2;

        const oddSemName = target === 'y1-y2' ? 'Sem 1' : target === 'y2-y3' ? 'Sem 3' : 'Sem 5';
        const evenSemName = target === 'y1-y2' ? 'Sem 2' : target === 'y2-y3' ? 'Sem 4' : 'Sem 6';

        checks.push({
          label: `${oddSemName} Backlogs (≤ 2)`,
          passed: oddOk,
          detail: `${oddFailed} failed subjects`
        });

        checks.push({
          label: `${evenSemName} Backlogs (≤ 2)`,
          passed: evenOk,
          detail: `${evenFailed} failed subjects`
        });

        if (!oddOk || !evenOk) {
          isEligible = false;
          statusType = 'drop';
        }

        // Gauge Rendering
        updateGauge('Total Backlogs', totalDegreeBacklogs, 4, isEligible);

        // State evaluation
        if (isEligible) {
          if (totalDegreeBacklogs > 0) {
            statusType = 'warning';
            statusMsg = 'ELIGIBLE (WITH BACKLOGS)';
            statusSubtitleText = 'PROVISIONAL ATKT PROMOTION';
            adviceText = `You are eligible for promotion under B.Sc/B.Com CBCS rules. However, you are carrying ${totalDegreeBacklogs} failed subjects. You must pass these in the next examination cycle.`;
          } else {
            statusType = 'eligible';
            statusMsg = 'ELIGIBLE (CLEARED ALL)';
            statusSubtitleText = 'REGULAR YEAR PROMOTION';
            adviceText = 'Fantastic! You have passed all subjects in the current year. You are fully eligible to proceed.';
          }
        } else {
          statusMsg = 'DETENTION / YEAR DROP';
          statusSubtitleText = 'ELIGIBILITY CRITERIA FAILED';
          if (!isPriorClear && target !== 'y1-y2') {
            adviceText = 'You face a Year Drop because you have not cleared your previous years completely. Under General Degree CBCS, you cannot enter Third Year (TY) with First Year (FY) KTs remaining.';
          } else {
            adviceText = `You have failed in more than 2 subjects in a semester. General degree rules permit a maximum of 2 backlogs per semester. You must clear these in the next supplementary cycle to resume progression.`;
          }
        }

      } else if (scheme === 'mu-nep') {
        const earnedCredits = parseInt(creditsNum.value) || 0;
        const limits = nepCreditsMapping[target] || { required: 32, max: 44 };

        const creditOk = earnedCredits >= limits.required;

        checks.push({
          label: `Earned Credit Threshold (≥ ${limits.required})`,
          passed: creditOk,
          detail: `${earnedCredits} / ${limits.max} credits accumulated`
        });

        if (!creditOk) {
          isEligible = false;
          statusType = 'drop';
        }

        // Gauge Rendering (based on credit fraction)
        updateGauge('Earned Credits', earnedCredits, limits.max, isEligible, true);

        // State evaluation
        if (isEligible) {
          if (earnedCredits < limits.max) {
            statusType = 'warning';
            statusMsg = 'ELIGIBLE (CREDIT MET)';
            statusSubtitleText = 'PROMOTED TO NEXT YEAR';
            adviceText = `You have earned ${earnedCredits} credits, satisfying the minimum ${limits.required} credits needed for promotion under NEP guidelines. Keep in mind that you must clear the remaining failed credits to avoid degree delays.`;
          } else {
            statusType = 'eligible';
            statusMsg = 'ELIGIBLE (CLEARED ALL)';
            statusSubtitleText = 'REGULAR YEAR PROMOTION';
            adviceText = 'Perfect score! You have secured 100% of the credits offered this year and are promoted with a clear record.';
          }
        } else {
          statusMsg = 'DETENTION / YEAR DROP';
          statusSubtitleText = 'CREDIT DEFICIENCY';
          adviceText = `You have earned ${earnedCredits} credits, which is below the minimum required ${limits.required} credits. You face a Year Drop. Prepare for backlog examinations in the winter/summer cycles to accumulate the missing credits.`;
        }

      } else if (scheme === 'custom') {
        const reqPrior = customReqPrior.checked;
        const maxHeads = parseInt(customMaxHeads.value) || 0;
        const maxEse = parseInt(customMaxEse.value) || 0;
        const minCredits = parseInt(customMinCredits.value) || 0;

        const inputHeads = parseInt(customInputHeads.value) || 0;
        const inputEse = parseInt(customInputEse.value) || 0;
        const inputCredits = parseInt(customInputCredits.value) || 0;
        const inputTotalCredits = parseInt(customInputTotalCredits.value) || 0;

        if (reqPrior) {
          const priorYearLabel = 'Prior Years Cleared';
          if (isPriorClear) {
            checks.push({ label: priorYearLabel, passed: true, detail: 'Cleared' });
          } else {
            checks.push({ label: priorYearLabel, passed: false, detail: 'outstanding KTs' });
            isEligible = false;
            statusType = 'drop';
          }
        }

        if (maxHeads > 0) {
          const headsOk = inputHeads <= maxHeads;
          checks.push({
            label: `Total Failed Heads (≤ ${maxHeads})`,
            passed: headsOk,
            detail: `${inputHeads} / ${maxHeads} failed`
          });
          if (!headsOk) {
            isEligible = false;
            statusType = 'drop';
          }
        }

        if (maxEse > 0) {
          const eseOk = inputEse <= maxEse;
          checks.push({
            label: `Theory/ESE Failed (≤ ${maxEse})`,
            passed: eseOk,
            detail: `${inputEse} / ${maxEse} failed`
          });
          if (!eseOk) {
            isEligible = false;
            statusType = 'drop';
          }
        }

        if (minCredits > 0) {
          const creditOk = inputCredits >= minCredits;
          checks.push({
            label: `Required Credits (≥ ${minCredits})`,
            passed: creditOk,
            detail: `${inputCredits} / ${inputTotalCredits || minCredits} earned`
          });
          if (!creditOk) {
            isEligible = false;
            statusType = 'drop';
          }
        }

        // Custom gauge (heads)
        const customLimit = maxHeads || maxEse || 10;
        updateGauge('Custom Backlogs', inputHeads, customLimit, isEligible);

        // State evaluation
        if (isEligible) {
          if (inputHeads > 0 || inputCredits < inputTotalCredits) {
            statusType = 'warning';
            statusMsg = 'ELIGIBLE (CUSTOM)';
            statusSubtitleText = 'LIMITS SATISFIED';
            adviceText = 'Your custom parameters show you are eligible to proceed. Make sure to plan your backlog preparation.';
          } else {
            statusType = 'eligible';
            statusMsg = 'ELIGIBLE (ALL CLEAR)';
            statusSubtitleText = 'REGULAR PROMOTION';
            adviceText = 'Congratulations! You have satisfied all conditions and are promoted.';
          }
        } else {
          statusMsg = 'DETENTION / YEAR DROP';
          statusSubtitleText = 'CUSTOM CRITERIA FAILED';
          adviceText = 'You are not eligible for promotion based on your custom-defined criteria. Check your inputs and backlog counters.';
        }
      } else if (scheme === 'autonomous') {
        // ─── Autonomous College Logic ────────────────────────────────────────────
        // Autonomous colleges have wildly different rules. This section models:
        //  1. Promotion Eligibility   – are you allowed to enter the next year?
        //  2. Current-Year Backlog Limit – max failed heads in the current year
        //  3. Golden KT Tracking     – prior-year backlogs (separate concern)
        // If year-clearance is NOT enforced, Golden KTs do NOT block promotion.
        const reqPrior = autonomousReqPrior ? autonomousReqPrior.checked : false;
        const maxHeads = autonomousMaxHeads ? (parseInt(autonomousMaxHeads.value) || 0) : 0; // 0 = unlimited
        const maxEse = autonomousMaxEse ? (parseInt(autonomousMaxEse.value) || 0) : 0;       // 0 = unlimited
        const maxGolden = autonomousMaxGolden ? (parseInt(autonomousMaxGolden.value) || 0) : 0; // 0 = unlimited

        const inputHeads = autonomousInputHeads ? (parseInt(autonomousInputHeads.value) || 0) : 0;
        const inputEse = autonomousInputEse ? (parseInt(autonomousInputEse.value) || 0) : 0;
        const inputGolden = autonomousInputGolden ? (parseInt(autonomousInputGolden.value) || 0) : 0;

        // 1. Promotion eligibility — prior year clearance (optional, college-specific)
        if (reqPrior && target !== 'y1-y2') {
          const priorYearLabel = target === 'y2-y3' ? 'First Year (Sem 1 & 2) Cleared' : 'First & Second Year (Sem 1-4) Cleared';
          if (isPriorClear) {
            checks.push({ label: priorYearLabel, passed: true, detail: 'No prior-year backlogs outstanding' });
          } else {
            checks.push({ label: priorYearLabel, passed: false, detail: 'Your college enforces year-clearance — prior backlogs block promotion' });
            isEligible = false;
            statusType = 'drop';
          }
        } else if (!reqPrior && target !== 'y1-y2') {
          // Year-clearance not enforced — Golden KTs are tracked but don't block promotion
          checks.push({
            label: 'Year-Clearance',
            passed: true,
            detail: 'Not enforced — Golden KTs from prior years do not block promotion (verify with your college)'
          });
        }

        // 2. Current-year failed heads check (only if college has a limit)
        if (maxHeads > 0) {
          const headsOk = inputHeads <= maxHeads;
          checks.push({
            label: `Current-Year Failed Heads (≤ ${maxHeads})`,
            passed: headsOk,
            detail: `${inputHeads} / ${maxHeads} failed heads`
          });
          if (!headsOk) {
            isEligible = false;
            statusType = 'drop';
          }
        } else if (inputHeads > 0) {
          checks.push({
            label: 'Current-Year Backlogs (no limit configured)',
            passed: true,
            detail: `${inputHeads} active backlog head(s) — verify if your college has a cap`
          });
        }

        // 3. Current-year ESE/theory check (only if college has a limit)
        if (maxEse > 0) {
          const eseOk = inputEse <= maxEse;
          checks.push({
            label: `Theory/ESE Failed (≤ ${maxEse})`,
            passed: eseOk,
            detail: `${inputEse} / ${maxEse} failed ESE papers`
          });
          if (!eseOk) {
            isEligible = false;
            statusType = 'drop';
          }
        }

        // 4. Golden KT (prior-year backlog) limit check
        if (!reqPrior && inputGolden > 0) {
          if (maxGolden > 0) {
            const goldenOk = inputGolden <= maxGolden;
            checks.push({
              label: `Golden KTs (prior-year limit ≤ ${maxGolden})`,
              passed: goldenOk,
              detail: `${inputGolden} Golden KT(s) tracked — ${goldenOk ? 'within limit' : 'exceeds college limit'}`
            });
            if (!goldenOk) {
              isEligible = false;
              statusType = 'drop';
            }
          } else {
            checks.push({
              label: 'Golden KTs (no limit set)',
              passed: true,
              detail: `${inputGolden} Golden KT(s) from prior years — being tracked, no cap configured`
            });
          }
        }

        // Gauge: show current-year heads (or golden if no current heads)
        const autoGaugeMax = maxHeads > 0 ? maxHeads : (inputHeads > 0 ? inputHeads + 4 : 8);
        updateGauge('Current-Year Backlog Heads', inputHeads, autoGaugeMax, isEligible);

        // State evaluation
        const hasActiveBacklogs = inputHeads > 0 || inputGolden > 0;
        if (isEligible) {
          if (hasActiveBacklogs) {
            statusType = 'warning';
            statusMsg = 'ELIGIBLE (BACKLOGS REMAIN)';
            statusSubtitleText = 'PROVISIONAL PROMOTION';
            const backlogSummary = [];
            if (inputHeads > 0) backlogSummary.push(`${inputHeads} current-year backlog head(s)`);
            if (inputGolden > 0) backlogSummary.push(`${inputGolden} Golden KT(s) from prior semesters`);
            adviceText = `You appear eligible to progress based on your configured rules. You have ${backlogSummary.join(' and ')}. Important: verify your eligibility directly with your exam section — autonomous rules vary per college and per ordinance year.`;
          } else {
            statusType = 'eligible';
            statusMsg = 'ELIGIBLE (ALL CLEAR)';
            statusSubtitleText = 'REGULAR PROMOTION';
            adviceText = 'All configured checks passed. You have no active backlogs. You should be eligible for regular promotion — confirm with your college exam section.';
          }
        } else {
          statusMsg = 'DETENTION / YEAR DROP';
          statusSubtitleText = 'CONFIGURED LIMIT EXCEEDED';
          if (reqPrior && !isPriorClear && target !== 'y1-y2') {
            adviceText = 'Your college enforces year-clearance. You have outstanding backlogs from a prior year that block your promotion. Focus on clearing those specific subjects in the next supplementary exam cycle. Confirm this rule with your exam cell.';
          } else if (maxGolden > 0 && inputGolden > maxGolden) {
            adviceText = `Your college limits Golden KTs (prior-year carry-overs) to ${maxGolden}. You have ${inputGolden} Golden KTs, which exceeds this limit. You must reduce your pending Golden KTs to be eligible for promotion.`;
          } else {
            adviceText = `You have exceeded the configured backlog limit for your autonomous college. Check your college's specific ordinance for the exact promotion criteria and attempt the supplementary exams.`;
          }
        }
      }

      // RENDER STANDING CARD COLORS & LED
      // Remove previous color classes
      statusCard.classList.remove(
        'bg-success/5', 'border-success/20', 'text-success',
        'bg-warning/5', 'border-warning/20', 'text-warning-deep',
        'bg-error/5', 'border-error/20', 'text-error'
      );
      statusLed.classList.remove('bg-success', 'bg-warning', 'bg-error');
      statusText.classList.remove('text-success', 'text-warning-deep', 'text-error');

      if (statusType === 'eligible') {
        statusCard.classList.add('bg-success/5', 'border-success/20');
        statusLed.classList.add('bg-success');
        statusText.classList.add('text-success');
        statusText.textContent = statusMsg;
      } else if (statusType === 'warning') {
        statusCard.classList.add('bg-warning/5', 'border-warning/20');
        statusLed.classList.add('bg-warning');
        statusText.classList.add('text-warning-deep');
        statusText.textContent = statusMsg;
      } else if (statusType === 'drop') {
        statusCard.classList.add('bg-error/5', 'border-error/20');
        statusLed.classList.add('bg-error');
        statusText.classList.add('text-error');
        statusText.textContent = statusMsg;
      }

      statusSubtitle.textContent = statusSubtitleText;
      adviceDesc.textContent = adviceText;

      // Render Progression Checks List
      checksList.innerHTML = '';
      checks.forEach(c => {
        const li = document.createElement('li');
        li.className = 'flex items-start gap-2.5 text-xs';
        
        const iconColor = c.passed ? 'text-success' : 'text-error';
        const svgPath = c.passed 
          ? '<circle cx="12" cy="12" r="10" /><path d="m9 12 2 2 4-4" />' 
          : '<circle cx="12" cy="12" r="10" /><path d="m15 9-6 6M9 9l6 6" />';

        li.innerHTML = `
          <svg class="h-4.5 w-4.5 ${iconColor} shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            ${svgPath}
          </svg>
          <div class="flex-1">
            <span class="font-medium text-ink">${c.label}</span>
            <span class="block text-[10px] text-mute font-mono mt-0.5">${c.detail}</span>
          </div>
        `;
        checksList.appendChild(li);
      });

      // Update Copy Report card template
      updateShareTemplate(statusMsg, statusSubtitleText, checks, adviceText);
      updateBacklogDashboard();
    }

    function updateBacklogDashboard() {
      if (!backlogActiveVal || !backlogOldestVal || !backlogGoldenVal || !backlogRatioVal) return;

      let activeCount = 0;
      let clearedCount = 0;
      let oldestSem = Infinity;
      let goldenCount = 0;

      const target = targetSelect.value;

      loggedCourses.forEach(c => {
        if (c.status === 'cleared') {
          clearedCount++;
        } else {
          activeCount++;
          const semNum = parseInt(c.sem);
          if (semNum < oldestSem) {
            oldestSem = semNum;
          }

          // Golden KT check: backlog in previous year(s)
          // y2-y3 target (TY entry, Sem 5/6) -> Golden KT if Sem 1 or 2
          // y3-y4 target (LY entry, Sem 7/8) -> Golden KT if Sem 1, 2, 3, or 4
          if (target === 'y2-y3' && semNum <= 2) {
            goldenCount++;
          } else if (target === 'y3-y4' && semNum <= 4) {
            goldenCount++;
          }
        }
      });

      backlogActiveVal.textContent = activeCount.toString();
      backlogActiveVal.className = `text-base font-bold ${activeCount > 0 ? 'text-error' : 'text-success'}`;

      backlogOldestVal.textContent = oldestSem === Infinity ? 'None' : `Sem ${oldestSem}`;
      backlogOldestVal.className = `text-base font-bold ${oldestSem === Infinity ? 'text-success' : 'text-ink'}`;

      backlogGoldenVal.textContent = goldenCount.toString();
      backlogGoldenVal.className = `text-base font-bold ${goldenCount > 0 ? 'text-error' : 'text-success'}`;

      const totalCount = activeCount + clearedCount;
      backlogRatioVal.textContent = `${clearedCount} / ${totalCount}`;
    }

    // Update the progress bar status
    function updateGauge(label, value, limit, isEligible, inverse = false) {
      gaugeLabel.textContent = label;
      
      let percent = limit > 0 ? (value / limit) * 100 : 0;
      if (percent > 100) percent = 100;
      if (percent < 0) percent = 0;

      gaugeNumbers.textContent = `${value} / ${limit} ${inverse ? 'credits' : 'max'}`;
      
      gaugeBar.style.width = `${percent}%`;
      gaugeBar.classList.remove('bg-success', 'bg-warning', 'bg-error');

      if (inverse) {
        // Higher is better (NEP credits)
        if (value >= limit) {
          gaugeBar.classList.add('bg-success');
        } else if (isEligible) {
          gaugeBar.classList.add('bg-warning');
        } else {
          gaugeBar.classList.add('bg-error');
        }
      } else {
        // Lower is better (backlogs)
        if (value === 0) {
          gaugeBar.classList.add('bg-success');
        } else if (isEligible) {
          gaugeBar.classList.add('bg-warning');
        } else {
          gaugeBar.classList.add('bg-error');
        }
      }
    }

    // Update Report Card Share Text
    let shareTextContent = "";
    function updateShareTemplate(status, subtitle, checks, advice) {
      const schemeText = schemeSelect.options[schemeSelect.selectedIndex].text;
      const targetText = targetSelect.options[targetSelect.selectedIndex].text;

      let msg = `🎓 ATKT & BACKLOG STANDINGS REPORT\n`;
      msg += `------------------------------------\n`;
      msg += `• Regulations: ${schemeText}\n`;
      msg += `• Target: ${targetText}\n`;
      msg += `• Result: ${status} (${subtitle})\n\n`;
      msg += `Progression Checks:\n`;
      
      checks.forEach(c => {
        const symbol = c.passed ? '✓' : '✗';
        msg += ` ${symbol} ${c.label} [${c.detail}]\n`;
      });
      
      msg += `\nAdvice:\n${advice}\n\n`;
      msg += `Analyze your stands at: ${SITE_URL}/atkt-eligibility-helper`;
      
      shareTextContent = msg;
    }

    // Share button listener
    shareBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(shareTextContent).then(() => {
        shareToast.classList.remove('opacity-0');
        shareToast.classList.add('opacity-100');
        setTimeout(() => {
          shareToast.classList.remove('opacity-100');
          shareToast.classList.add('opacity-0');
        }, 2000);
      }).catch(err => {
        console.error('Failed to copy text: ', err);
      });
    });

    // Run Initialization
    init();
  });
</script>
