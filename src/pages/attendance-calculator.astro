---
import BaseLayout from '../layouts/BaseLayout.astro';

const faq = [
  {
    question: "How does the Bunk Calculator determine skip limits?",
    answer: "If your current attendance is above your target percentage, the calculator determines the maximum number of consecutive classes you can skip without your percentage dropping below that threshold. The formula is: Bunk Limit = Math.floor((100 * Attended - Target * Conducted) / Target)."
  },
  {
    question: "How is the required class count calculated for low attendance?",
    answer: "If your attendance falls below the target (e.g., 75%), the calculator finds the minimum number of consecutive upcoming lectures you must attend to pull your average back up. The formula is: Required Classes = Math.ceil((Target * Conducted - 100 * Attended) / (100 - Target))."
  },
  {
    question: "Is the 75% attendance rule mandatory in all Indian colleges?",
    answer: "Under UGC, AICTE, and bar council regulations, a 75% attendance threshold is standard in most Indian universities (such as SPPU, Mumbai University, VTU, and JNTU) to be eligible for final exams. Some universities allow relaxation down to 60% or 65% in case of documented medical emergencies."
  },
  {
    question: "What happens if my attendance falls below 75% in an Indian university?",
    answer: "If your attendance falls below 75% without an approved condonation (such as a medical certificate or sports exemption), you are marked as 'detained'. Detained students are barred from appearing in the end-semester exams and must repeat the semester or the courses in the following academic year."
  },
  {
    question: "What is 'condonation' of attendance, and how do I apply for it?",
    answer: "Condonation is the formal excusing of an attendance shortage (usually up to 10% or 15%) by the college principal or university authorities. It is granted for genuine reasons like severe illness or representing the college at sports/cultural events. To apply, you must submit a formal application accompanied by official medical certificates or participation letters before the semester ends."
  },
  {
    question: "Can I track multiple subjects separately?",
    answer: "Yes. Using our built-in Subject Manager, you can save your attendance values for individual subjects (e.g., Math, Physics, CS) locally on your device. It requires no login and uses your browser's LocalStorage."
  },
  {
    question: "Do you store my attendance data on your servers?",
    answer: "No. Student Utility Hub values your privacy. All your saved subjects, attendance counts, and settings are stored locally in your browser's LocalStorage. No data is ever transmitted to our servers or shared with third parties."
  }
];
---

<BaseLayout
  title="Attendance Calculator & Bunk Tracker (75% Rule)"
  description="Free college attendance calculator and bunk planner. Calculate your current percentage, find how many lectures you can safely skip, or how many you must attend to maintain 75% attendance."
  {faq}
>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Breadcrumb & Header -->
    <nav class="flex mb-4" aria-label="Breadcrumb">
      <ol class="inline-flex items-center gap-1.5 font-mono text-[11px] text-mute">
        <li>
          <a href="/" class="hover:text-ink transition-colors">Home</a>
        </li>
        <li class="flex items-center gap-1.5 select-none">
          <span>/</span>
          <span class="text-body font-semibold">Attendance Calculator</span>
        </li>
      </ol>
    </nav>

    <div class="mb-8">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="rounded-full border border-hairline bg-canvas px-3 py-1 font-mono text-[11px] font-semibold text-mute">
          Tool 01
        </span>
        <span class="font-mono text-[11px] uppercase tracking-wider text-mute">
          Know when to bunk.
        </span>
      </div>
      <h1 class="mt-4 font-sans text-3xl font-semibold tracking-[-0.96px] text-ink sm:text-4xl">
        Attendance Calculator & Bunk Tracker
      </h1>
      <p class="mt-2 max-w-2xl text-sm leading-relaxed text-body">
        Check your current status, calculate skips, and plan your academic recovery instantly. Save subjects locally to track progress over the semester.
      </p>
    </div>

    <!-- Main Tool Workspace -->
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">
      <!-- Calculator Inputs & Subject Manager -->
      <div class="flex flex-col gap-6 lg:col-span-7">
        
        <!-- Interactive Form -->
        <div class="rounded-md border border-hairline bg-canvas p-4 sm:p-6 shadow-level-2 transition-colors duration-200">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-mute font-mono mb-6">
            Calculator Inputs
          </h2>

          <div class="flex flex-col gap-6">
            <!-- Target Percentage Selector -->
            <div>
              <label for="target-percent" class="block text-sm font-medium text-ink mb-2">
                Target Attendance Percentage
              </label>
              <div class="flex items-center gap-4">
                <input
                  type="range"
                  id="target-percent-range"
                  min="50"
                  max="100"
                  value="75"
                  step="5"
                  class="h-1.5 flex-1 cursor-pointer appearance-none rounded-full bg-canvas-soft-2 accent-primary"
                  aria-label="Target percentage slider"
                />
                <input
                  type="number"
                  id="target-percent"
                  value="75"
                  min="50"
                  max="100"
                  inputmode="numeric"
                  autocomplete="off"
                  class="h-9 w-20 rounded-sm border border-hairline bg-canvas text-center text-sm font-semibold text-ink focus:outline-none"
                />
                <span class="font-mono text-sm text-mute font-semibold">%</span>
              </div>
            </div>

            <!-- Total Classes Conducted -->
            <div>
              <div class="flex items-center justify-between mb-2">
                <label for="conducted" class="text-sm font-medium text-ink">
                  Total Classes Conducted
                </label>
                <span class="text-[11px] font-mono text-mute">Includes labs & lectures</span>
              </div>
              <div class="flex items-center gap-4">
                <input
                  type="range"
                  id="conducted-range"
                  min="0"
                  max="150"
                  value="40"
                  class="h-1.5 flex-1 cursor-pointer appearance-none rounded-full bg-canvas-soft-2 accent-primary"
                  aria-label="Total conducted classes slider"
                />
                <input
                  type="number"
                  id="conducted"
                  value="40"
                  min="0"
                  placeholder="40…"
                  inputmode="numeric"
                  autocomplete="off"
                  class="h-9 w-20 rounded-sm border border-hairline bg-canvas text-center text-sm font-semibold text-ink focus:outline-none"
                />
                <span class="font-mono text-sm text-mute font-semibold">lectures</span>
              </div>
            </div>

            <!-- Classes Attended -->
            <div>
              <div class="flex items-center justify-between mb-2">
                <label for="attended" class="text-sm font-medium text-ink">
                  Classes Attended
                </label>
                <span id="attended-warning" class="text-xs text-error font-medium hidden">Cannot exceed conducted!</span>
              </div>
              <div class="flex items-center gap-4">
                <input
                  type="range"
                  id="attended-range"
                  min="0"
                  max="150"
                  value="32"
                  class="h-1.5 flex-1 cursor-pointer appearance-none rounded-full bg-canvas-soft-2 accent-primary"
                  aria-label="Classes attended slider"
                />
                <input
                  type="number"
                  id="attended"
                  value="32"
                  min="0"
                  placeholder="32…"
                  inputmode="numeric"
                  autocomplete="off"
                  class="h-9 w-20 rounded-sm border border-hairline bg-canvas text-center text-sm font-semibold text-ink focus:outline-none"
                />
                <span class="font-mono text-sm text-mute font-semibold">lectures</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Subject Profiles Manager -->
        <div class="rounded-md border border-hairline bg-canvas p-4 sm:p-6 shadow-level-2 transition-colors duration-200">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-sm font-semibold uppercase tracking-wider text-mute font-mono">
              Subject Manager
            </h2>
            <span class="text-[10px] font-mono bg-canvas-soft-2 border border-hairline rounded-full px-2 py-0.5 text-mute">
              Offline Cache
            </span>
          </div>

          <!-- Save Current Values Panel -->
          <div class="flex flex-col sm:flex-row gap-3 mb-6">
            <input
              type="text"
              id="subject-name"
              placeholder="e.g., Mathematics-II…"
              class="h-9 flex-1 rounded-sm border border-hairline bg-canvas px-3 text-sm text-ink placeholder-mute focus:outline-none"
              autocomplete="off"
              spellcheck="false"
            />
            <button
              id="save-subject"
              class="h-9 inline-flex items-center justify-center rounded-sm bg-primary px-4 text-xs font-semibold text-on-primary hover:bg-ink/90 transition-colors cursor-pointer"
            >
              Save Subject
            </button>
          </div>

          <!-- Subject Dashboard Grid -->
          <div id="subject-list" class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-h-60 overflow-y-auto pr-1">
            <!-- Dynamically populated -->
          </div>
          
          <div id="subject-empty-state" class="py-6 text-center border border-dashed border-hairline rounded-sm bg-canvas-soft">
            <p class="text-xs text-mute font-medium">No saved subjects yet. Enter a name above to start tracking.</p>
          </div>
        </div>

      </div>

      <!-- Calculation Outputs & Share Panel -->
      <div class="flex flex-col gap-6 lg:col-span-5">
        
        <!-- Live Calculations Card -->
        <div class="rounded-md border border-hairline bg-canvas p-4 sm:p-6 shadow-level-2 transition-colors duration-200">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-mute font-mono mb-6">
            Calculated Results
          </h2>

          <!-- Visual Gauge Block -->
          <div class="flex flex-col items-center justify-center py-4 text-center">
            <div id="gauge-container" class="relative flex h-36 w-36 items-center justify-center rounded-full border-[10px] border-canvas-soft-2 bg-canvas transition-colors duration-300">
              <div class="flex flex-col items-center">
                <!-- Large current % display with tabular numbers -->
                <span id="result-percent" class="font-sans text-3xl font-semibold tracking-tight tabular-nums text-ink">
                  80.0%
                </span>
                <span class="text-[10px] font-mono font-medium text-mute mt-0.5">CURRENT</span>
              </div>
              <!-- Colored status circle indicator -->
              <span id="gauge-status-led" class="absolute top-2 right-2 h-3.5 w-3.5 rounded-full border-2 border-canvas shadow-sm bg-success transition-all duration-300"></span>
            </div>
            
            <p id="gauge-advice" class="mt-5 text-sm leading-relaxed text-body font-medium px-4">
              Your attendance is in the safe zone.
            </p>

            <!-- Progress Bar toward target attendance -->
            <div class="w-full mt-6 px-4">
              <div class="flex justify-between text-[10px] font-mono text-mute mb-1.5">
                <span>0%</span>
                <span id="target-marker" class="font-semibold text-primary">Target: 75%</span>
                <span>100%</span>
              </div>
              <div class="h-2 w-full rounded-full bg-canvas-soft-2 overflow-hidden border border-hairline relative">
                <!-- Target vertical line marker -->
                <div id="target-line" class="absolute top-0 bottom-0 w-0.5 bg-primary/40 z-10 transition-all duration-300" style="left: 75%;"></div>
                <!-- Progress fill -->
                <div id="progress-bar-fill" class="h-full bg-success transition-all duration-300" style="width: 80%;"></div>
              </div>
            </div>

            <!-- Exam Eligibility Status Card -->
            <div id="eligibility-card" class="mt-6 w-full rounded-sm border p-3.5 flex items-start gap-3 text-left transition-all duration-300 bg-success/5 border-success/20">
              <div id="eligibility-icon" class="text-success mt-0.5">
                <!-- Dynamic svg check/alert -->
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="10" /><path d="m9 12 2 2 4-4" />
                </svg>
              </div>
              <div>
                <h4 id="eligibility-title" class="text-xs font-semibold uppercase tracking-wider text-success font-mono">
                  Exam Eligible
                </h4>
                <p id="eligibility-desc" class="text-xs text-body mt-1 leading-normal">
                  Your attendance is above the 75% threshold. You are fully eligible for semester exams.
                </p>
              </div>
            </div>

          </div>

          <div class="h-px bg-hairline my-6"></div>

          <!-- Concrete Outcomes -->
          <div class="flex flex-col gap-4">
            <!-- Safe Bunks Info -->
            <div class="flex items-center justify-between">
              <span class="text-sm text-body">Safe Bunks Remaining:</span>
              <span id="result-bunks" class="font-mono text-sm font-semibold text-success bg-success/10 px-2.5 py-0.5 rounded-full">
                0 classes
              </span>
            </div>

            <!-- Recovery Plan Info -->
            <div class="flex items-center justify-between">
              <span class="text-sm text-body">Recovery Classes Needed:</span>
              <span id="result-recovery" class="font-mono text-sm font-semibold text-mute bg-canvas-soft-2 px-2.5 py-0.5 rounded-full">
                0 classes
              </span>
            </div>
          </div>
        </div>

        <!-- Share & Export Card -->
        <div class="rounded-md border border-hairline bg-canvas p-4 sm:p-6 shadow-level-2 transition-colors duration-200">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-mute font-mono mb-4">
            Share Calculations
          </h2>
          <p class="text-xs text-mute mb-4 leading-relaxed">
            Generate a clean, copy-paste format to share with classmates on WhatsApp or Telegram groups.
          </p>

          <div class="rounded-sm border border-hairline bg-canvas-soft-2 p-3 font-mono text-[11px] text-body whitespace-pre-wrap select-all leading-normal" id="share-text-box">
            Loading results card…
          </div>

          <button
            id="copy-share-btn"
            class="mt-4 w-full h-9 inline-flex items-center justify-center gap-2 rounded-sm bg-primary px-4 text-xs font-semibold text-on-primary hover:bg-ink/90 transition-colors cursor-pointer"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
            </svg>
            <span id="copy-btn-text">Copy Results</span>
          </button>
        </div>

      </div>
    </div>

    <!-- Attendance Forecast Grid Panel (Full Width) -->
    <div class="rounded-md border border-hairline bg-canvas p-4 sm:p-6 shadow-level-2 mt-8 transition-colors duration-200">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-wider text-mute font-mono">
            Attendance Forecast
          </h2>
          <p class="text-xs text-mute mt-1">
            Simulate how skipping or attending future classes impacts your percentage.
          </p>
        </div>
        
        <!-- Tab Switches (Vercel Pill style) -->
        <div class="inline-flex rounded-full bg-canvas-soft-2 p-0.5 border border-hairline self-start sm:self-auto">
          <button
            id="tab-bunks"
            class="rounded-full px-3 py-1 text-xs font-medium bg-canvas text-ink shadow-sm transition-all focus:outline-none cursor-pointer"
          >
            Bunk Simulation (+1 to +10)
          </button>
          <button
            id="tab-attendance"
            class="rounded-full px-3 py-1 text-xs font-medium text-body hover:text-ink transition-all focus:outline-none cursor-pointer"
          >
            Attend Simulation (+1 to +10)
          </button>
        </div>
      </div>

      <!-- Bunk Forecast Table -->
      <div id="bunks-forecast-container" class="overflow-x-auto -mx-4 sm:mx-0">
        <div class="inline-block min-w-full align-middle px-4 sm:px-0">
          <table class="w-full border-collapse text-left">
            <thead>
              <tr class="border-b border-hairline bg-canvas-soft-2">
                <th class="py-2.5 px-4 font-mono text-[10px] font-semibold text-mute uppercase tracking-wider">Missed Lectures</th>
                <th class="py-2.5 px-4 font-mono text-[10px] font-semibold text-mute uppercase tracking-wider">Projected Conducted</th>
                <th class="py-2.5 px-4 font-mono text-[10px] font-semibold text-mute uppercase tracking-wider text-right">Projected Attendance</th>
                <th class="py-2.5 px-4 font-mono text-[10px] font-semibold text-mute uppercase tracking-wider text-right">Status</th>
              </tr>
            </thead>
            <tbody id="bunks-forecast-body" class="divide-y divide-hairline font-mono text-xs text-body tabular-nums">
              <!-- Dynamically populated -->
            </tbody>
          </table>
        </div>
      </div>

      <!-- Attend Forecast Table (Hidden by default) -->
      <div id="attendance-forecast-container" class="hidden overflow-x-auto -mx-4 sm:mx-0">
        <div class="inline-block min-w-full align-middle px-4 sm:px-0">
          <table class="w-full border-collapse text-left">
            <thead>
              <tr class="border-b border-hairline bg-canvas-soft-2">
                <th class="py-2.5 px-4 font-mono text-[10px] font-semibold text-mute uppercase tracking-wider">Attended Lectures</th>
                <th class="py-2.5 px-4 font-mono text-[10px] font-semibold text-mute uppercase tracking-wider">Projected Conducted</th>
                <th class="py-2.5 px-4 font-mono text-[10px] font-semibold text-mute uppercase tracking-wider text-right">Projected Attendance</th>
                <th class="py-2.5 px-4 font-mono text-[10px] font-semibold text-mute uppercase tracking-wider text-right">Status</th>
              </tr>
            </thead>
            <tbody id="attendance-forecast-body" class="divide-y divide-hairline font-mono text-xs text-body tabular-nums">
              <!-- Dynamically populated -->
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Detailed Guide Section -->
    <section class="py-16 mt-16 border-t border-hairline transition-colors duration-200">
      <div class="mx-auto max-w-4xl">
        <span class="font-mono text-[11px] uppercase tracking-wider text-mute block text-center mb-2">Detailed Guide</span>
        <h2 class="text-center font-sans text-2xl font-semibold tracking-tight text-ink md:text-3xl mb-12 animate-fade-in">
          Understanding College Attendance & Bunk Mathematics
        </h2>

        <div class="prose prose-sm max-w-none text-body leading-relaxed space-y-8 font-sans">
          <div>
            <p>
              Balancing your academic commitments with project work, internships, self-study, and extracurricular activities is one of the most challenging aspects of modern college life in India. In many universities, maintaining a certain attendance percentage is not just recommended; it is a statutory mandate. The dreaded "75% attendance rule" is a source of constant stress for millions of students.
            </p>
            <p class="mt-4">
              To navigate this requirement without compromising your academic standing or your health, you need clear data. Our Attendance Calculator & Bunk Tracker is designed to replace guesswork with precise math. By understanding how your attendance percentage is calculated and how bunk math works, you can schedule your classes, allocate time to other productive activities, and plan your exam eligibility in advance.
            </p>
          </div>

          <div>
            <h3 class="font-sans text-lg font-semibold tracking-tight text-ink mb-3">
              How Attendance Percentage Is Calculated
            </h3>
            <p>
              Calculating your attendance percentage is a simple mathematical ratio. It measures the number of classes you attended against the total number of classes that your college conducted. The standard formula is:
            </p>
            
            <div class="my-6 rounded-sm border border-hairline bg-canvas-soft-2 p-4 text-center font-mono text-sm text-ink leading-relaxed shadow-sm">
              Attendance Percentage = (Classes Attended / Classes Conducted) &times; 100
            </div>

            <p>
              To calculate your current standing, follow these steps:
            </p>
            <ol class="list-decimal list-inside space-y-2 mt-4 ml-2">
              <li>
                <strong class="text-ink">Identify Classes Attended:</strong> Count every lecture, laboratory class, seminar, and tutorial session where you were physically present and marked present by the lecturer.
              </li>
              <li>
                <strong class="text-ink">Identify Classes Conducted:</strong> Sum all the lectures and practical classes that actually took place. Note that officially cancelled classes, national holidays, or college-wide strikes do not count as conducted classes.
              </li>
              <li>
                <strong class="text-ink">Divide and Multiply:</strong> Divide the number of attended lectures by the number of conducted lectures, and multiply the quotient by 100.
              </li>
            </ol>

            <p class="mt-4">
              For example, let's assume your engineering college conducted a total of 60 lectures in Mathematics so far. If you attended 48 of those sessions, your calculation would look like this:
            </p>
            <div class="my-4 rounded-sm border border-hairline bg-canvas-soft-2 p-3 font-mono text-xs text-ink leading-relaxed pl-6">
              Current Percentage = (48 / 60) &times; 100 = 80.0%
            </div>
            <p class="mt-4">
              Keep in mind that some colleges calculate attendance separately for theory lectures and practical labs, while others look at a cumulative average. If your college separates them, you will need to run the calculation for each course code separately.
            </p>
          </div>

          <div>
            <h3 class="font-sans text-lg font-semibold tracking-tight text-ink mb-3">
              How Bunk Calculations Work
            </h3>
            <p>
              The term "bunking" or skipping a class requires careful mathematical validation. A student typically wants to know one of two things: how many classes they can safely skip without falling below their target (the Bunk Limit), or how many classes they must attend in a row to catch up if their attendance has already fallen below the threshold (the Recovery Plan).
            </p>

            <h4 class="font-sans text-sm font-semibold text-ink mt-6 mb-2">
              1. The Safe Bunk Limit Math (When Above Target)
            </h4>
            <p>
              If your current attendance percentage is higher than your target (e.g., you are at 85% and your target is 75%), you have a safety cushion. The formula to find the exact number of consecutive classes you can skip is:
            </p>

            <div class="my-6 rounded-sm border border-hairline bg-canvas-soft-2 p-4 text-center font-mono text-sm text-ink leading-relaxed shadow-sm">
              Safe Bunk Limit = Math.floor((100 &times; Attended - Target &times; Conducted) / Target)
            </div>

            <p>
              The formula uses the "floor" function (rounding down) because bunking is discrete; you cannot skip half a lecture. Let's walk through an example. Suppose you have attended 45 out of 50 classes, and your target is 75%:
            </p>
            <div class="my-4 rounded-sm border border-hairline bg-canvas-soft-2 p-3 font-mono text-xs text-ink leading-relaxed pl-6 space-y-1">
              <div>• Attended (A) = 45, Conducted (C) = 50, Target (T) = 75</div>
              <div>• Step 1: 100 &times; 45 = 4500</div>
              <div>• Step 2: 75 &times; 50 = 3750</div>
              <div>• Step 3: (4500 - 3750) = 750</div>
              <div>• Step 4: 750 / 75 = 10 classes</div>
            </div>
            <p class="mt-4">
              This means you can skip the next 10 consecutive lectures. After skipping 10 classes, the total conducted lectures will increase to 60, but your attended lectures will remain 45. Your new percentage will be (45 / 60) &times; 100 = 75.0%, keeping you exactly at the eligibility line.
            </p>

            <h4 class="font-sans text-sm font-semibold text-ink mt-6 mb-2">
              2. The Attendance Recovery Plan Math (When Below Target)
            </h4>
            <p>
              If you have skipped too many classes and your attendance is below the threshold (e.g., you are at 60% and need to reach 75%), you are in an attendance deficit. The formula to calculate the minimum number of consecutive upcoming classes you must attend is:
            </p>

            <div class="my-6 rounded-sm border border-hairline bg-canvas-soft-2 p-4 text-center font-mono text-sm text-ink leading-relaxed shadow-sm">
              Required Classes = Math.ceil((Target &times; Conducted - 100 &times; Attended) / (100 - Target))
            </div>

            <p>
              We use the "ceiling" function (rounding up) because you must attend full lectures to build up your average. Let's run an example where a student has attended 25 out of 40 conducted classes (62.5% current attendance) and needs to reach 75%:
            </p>
            <div class="my-4 rounded-sm border border-hairline bg-canvas-soft-2 p-3 font-mono text-xs text-ink leading-relaxed pl-6 space-y-1">
              <div>• Attended (A) = 25, Conducted (C) = 40, Target (T) = 75</div>
              <div>• Step 1: 75 &times; 40 = 3000</div>
              <div>• Step 2: 100 &times; 25 = 2500</div>
              <div>• Step 3: (3000 - 2500) = 500</div>
              <div>• Step 4: (100 - 75) = 25</div>
              <div>• Step 5: 500 / 25 = 20 classes</div>
            </div>
            <p class="mt-4">
              This indicates you must attend the next 20 consecutive classes without skipping a single one. After 20 attended classes, the total conducted classes will be 60, and your attended classes will rise to 45. Your resulting attendance will be (45 / 60) &times; 100 = 75.0%.
            </p>
          </div>

          <div>
            <h3 class="font-sans text-lg font-semibold tracking-tight text-ink mb-3">
              75% Attendance Rule
            </h3>
            <p>
              The "75% attendance rule" is a widely recognized academic regulation in the Indian higher education system. It has been institutionalized by key regulatory bodies to maintain the quality and rigor of university degrees.
            </p>
            <p class="mt-4">
              Regulatory councils such as the <strong class="text-ink">University Grants Commission (UGC)</strong>, the <strong class="text-ink">All India Council for Technical Education (AICTE)</strong>, the <strong class="text-ink">Bar Council of India (BCI)</strong>, and the <strong class="text-ink">National Medical Commission (NMC)</strong> mandate that a student must have a minimum of 75% attendance in theory lectures and laboratory practicals to be eligible to appear for the final semester examinations.
            </p>
            <p class="mt-4">
              The rule is enforced for several reasons:
            </p>
            <ul class="list-disc list-inside space-y-2 mt-4 ml-2">
              <li>
                <strong class="text-ink">Active Classroom Engagement:</strong> Lectures are not just about textbooks; they involve real-time discussions, student-teacher interactions, and peer explanations that cannot be replicated by studying notes at home.
              </li>
              <li>
                <strong class="text-ink">Continuous Internal Evaluation (CIE):</strong> Modern academic programs rely on quizzes, laboratory experiments, presentations, and viva-voce assessments that take place in the classroom. Missing these directly impacts internal marks.
              </li>
              <li>
                <strong class="text-ink">Professional Discipline:</strong> In professional courses like engineering, medicine, and law, consistency and discipline are vital skills. Setting attendance requirements instills structured habits before students enter the workforce.
              </li>
            </ul>
          </div>

          <div>
            <h3 class="font-sans text-lg font-semibold tracking-tight text-ink mb-3">
              Attendance Rules In Indian Colleges
            </h3>
            <p>
              While the general guideline of 75% is standard, individual universities and colleges in India have set their own specific ordinances, penalties, and relaxation policies (commonly known as "condonation").
            </p>

            <div class="space-y-6 mt-6">
              <div class="border-l-2 border-hairline pl-4">
                <h4 class="font-sans text-sm font-semibold text-ink">Savitribai Phule Pune University (SPPU)</h4>
                <p class="text-xs text-body mt-1 leading-relaxed">
                  SPPU mandates 75% attendance separately for theory lectures and practical sessions. The university principal or Head of the Department has the authority to condone a shortage of up to 15% (bringing the minimum threshold to 60%) in cases of genuine medical conditions, participation in state/national sports tournaments, or cultural activities. Proper documentation, like a medical certificate or formal invitation, is mandatory.
                </p>
              </div>

              <div class="border-l-2 border-hairline pl-4">
                <h4 class="font-sans text-sm font-semibold text-ink">Mumbai University (MU)</h4>
                <p class="text-xs text-body mt-1 leading-relaxed">
                  Under Mumbai University Ordinance O.6086, a student is expected to maintain 75% attendance. The College Attendance Committee and Principal have the authority to grant condonation for attendance between 50% and 74% under strict medical grounds or official representation in co-curricular events. Any student falling below 50% is generally detained and barred from writing examinations.
                </p>
              </div>

              <div class="border-l-2 border-hairline pl-4">
                <h4 class="font-sans text-sm font-semibold text-ink">Visvesvaraya Technological University (VTU)</h4>
                <p class="text-xs text-body mt-1 leading-relaxed">
                  VTU (Karnataka) requires a high standard of 85% attendance. Condonation of up to 10% (from 85% down to 75%) is permitted only under strict medical circumstances. An official medical certificate signed by a government medical officer, along with an official application, must be submitted to the college. Students with less than 75% attendance are ineligible to write exams.
                </p>
              </div>

              <div class="border-l-2 border-hairline pl-4">
                <h4 class="font-sans text-sm font-semibold text-ink">Jawaharlal Nehru Technological University (JNTU)</h4>
                <p class="text-xs text-body mt-1 leading-relaxed">
                  JNTU requires 75% attendance. Shortage of attendance in the range of 65% to 74% can be condoned by the College Academic Committee on medical grounds or sports participation. A condonation fee is levied on students who receive this exemption. Students with less than 65% attendance are detained and must re-register for the semester.
                </p>
              </div>

              <div class="border-l-2 border-hairline pl-4">
                <h4 class="font-sans text-sm font-semibold text-ink">Anna University</h4>
                <p class="text-xs text-body mt-1 leading-relaxed">
                  Anna University mandates 75% overall attendance. Students with attendance between 65% and 74% due to medical reasons, hospitalization, or official college events can apply for condonation. Students below the 65% mark are barred from examinations and must repeat the semester in the next academic year.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Related Utilities Grid -->
        <div class="mt-16 border-t border-hairline pt-12">
          <h3 class="font-sans text-lg font-semibold tracking-tight text-ink mb-6">
            Explore More Academic Utilities
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a href="/gpa-calculator" class="group rounded-md border border-hairline bg-canvas p-5 hover:border-ink transition-all shadow-sm hover:shadow-md">
              <h4 class="font-sans text-sm font-semibold text-ink group-hover:text-primary transition-colors flex items-center justify-between">
                <span>GPA Calculator</span>
                <svg class="h-4 w-4 text-mute group-hover:text-ink transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
