---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact & Feedback"
  description="Send your feature requests, bugs, or feedback for Student Utility Hub."
>
  <div class="mx-auto max-w-lg px-4 py-16 sm:px-6 lg:px-8">
    <span class="rounded-full border border-hairline bg-canvas px-3 py-1 font-mono text-xs font-semibold text-mute">
      Get in Touch
    </span>
    <h1 class="mt-4 font-sans text-3xl font-semibold tracking-[-0.96px] text-ink sm:text-4xl">
      Contact & Feedback.
    </h1>
    <p class="mt-2 text-sm text-body leading-relaxed">
      Have a feature suggestion? Found a formula discrepancy? Let us know and we'll fix it immediately.
    </p>

    <!-- Feedback Form -->
    <form id="contact-form" class="mt-10 flex flex-col gap-5 border border-hairline bg-canvas p-6 rounded-md shadow-level-2 transition-colors duration-200">
      <!-- Success Banner (Hidden by default) -->
      <div
        id="success-banner"
        class="hidden rounded-sm bg-success/10 border border-success/20 p-4 text-sm text-success font-medium animate-fade-in"
        role="alert"
        aria-live="polite"
      >
        Thank you! Your feedback has been simulated successfully. We'll check the formulas and get back to you if needed.
      </div>

      <!-- Error Banner (Hidden by default) -->
      <div
        id="error-banner"
        class="hidden rounded-sm bg-error/10 border border-error/20 p-4 text-sm text-error-deep font-medium animate-fade-in"
        role="alert"
        aria-live="polite"
      >
        Please fill out all fields before submitting.
      </div>

      <!-- Name Input -->
      <div>
        <label for="user-name" class="block text-xs font-mono font-semibold uppercase tracking-wider text-mute mb-2">
          Your Name
        </label>
        <input
          type="text"
          id="user-name"
          name="name"
          placeholder="e.g., Rohan Sharma…"
          class="h-10 w-full rounded-sm border border-hairline bg-canvas px-3 text-sm text-ink placeholder-mute focus:outline-none"
          required
          autocomplete="name"
        />
      </div>

      <!-- Email Input -->
      <div>
        <label for="user-email" class="block text-xs font-mono font-semibold uppercase tracking-wider text-mute mb-2">
          Email Address
        </label>
        <input
          type="email"
          id="user-email"
          name="email"
          placeholder="e.g., rohan@college.edu…"
          class="h-10 w-full rounded-sm border border-hairline bg-canvas px-3 text-sm text-ink placeholder-mute focus:outline-none"
          required
          autocomplete="email"
          spellcheck="false"
        />
      </div>

      <!-- Topic Dropdown -->
      <div>
        <label for="topic" class="block text-xs font-mono font-semibold uppercase tracking-wider text-mute mb-2">
          Topic / Category
        </label>
        <select
          id="topic"
          name="topic"
          class="h-10 w-full rounded-sm border border-hairline bg-canvas px-3 text-sm text-ink focus:outline-none"
          required
        >
          <option value="feedback">General Feedback</option>
          <option value="bug">Report a Bug / Formula Error</option>
          <option value="request">Request a New Tool</option>
          <option value="partnership">Sponsorship / Ads</option>
        </select>
      </div>

      <!-- Message Area -->
      <div>
        <label for="message" class="block text-xs font-mono font-semibold uppercase tracking-wider text-mute mb-2">
          Message
        </label>
        <textarea
          id="message"
          name="message"
          rows="5"
          placeholder="Tell us what tool you need or what formula needs updating…"
          class="w-full rounded-sm border border-hairline bg-canvas p-3 text-sm text-ink placeholder-mute focus:outline-none resize-none"
          required
        ></textarea>
      </div>

      <!-- Submit Button -->
      <button
        type="submit"
        id="submit-btn"
        class="mt-2 h-10 w-full inline-flex items-center justify-center rounded-sm bg-primary px-4 text-sm font-semibold text-on-primary hover:bg-ink/90 transition-colors focus:outline-none"
      >
        <span id="btn-label" class="inline-flex items-center gap-2">
          Send Message
        </span>
      </button>
    </form>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successBanner = document.getElementById('success-banner');
  const errorBanner = document.getElementById('error-banner');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const btnLabel = document.getElementById('btn-label');

  if (form && submitBtn && btnLabel) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      if (successBanner) successBanner.classList.add('hidden');
      if (errorBanner) errorBanner.classList.add('hidden');

      // Form validation check
      const inputs = form.querySelectorAll('input[required], textarea[required]');
      let isValid = true;
      inputs.forEach(input => {
        const htmlInput = input as HTMLInputElement;
        if (!htmlInput.value.trim()) {
          isValid = false;
        }
      });

      if (!isValid) {
        if (errorBanner) errorBanner.classList.remove('hidden');
        return;
      }

      // Enter loading state
      submitBtn.disabled = true;
      btnLabel.innerHTML = `Sending… <svg class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>`;

      // Simulate API submit delay
      setTimeout(() => {
        // Clear inputs
        form.reset();

        // Exit loading state
        submitBtn.disabled = false;
        btnLabel.innerHTML = `Send Message`;

        // Show success
        if (successBanner) {
          successBanner.classList.remove('hidden');
          successBanner.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }, 1500);
    });
  }
</script>
