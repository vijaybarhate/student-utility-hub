---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/attendance-calculator', label: 'Attendance Calc' },
  { href: '/gpa-calculator', label: 'GPA Calc' },
  { href: '/cgpa-to-percentage', label: 'CGPA to %' },
  { href: '/marks-needed-to-pass', label: 'Pass Marks' },
  { href: '/atkt-eligibility-helper', label: 'ATKT Helper' },
];
---

<header class="sticky top-0 z-50 w-full border-b border-hairline bg-canvas/80 backdrop-blur-md transition-colors duration-200">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <div class="flex items-center gap-6">
      <a href="/" class="flex items-center gap-2.5 group focus:outline-none">
        <!-- Stark minimal triangle icon inspired by Vercel -->
        <svg
          class="h-5 w-5 fill-ink stroke-ink transition-transform duration-200 group-hover:scale-105"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="M12 2L2 22h20L12 2z" stroke-width="2" stroke-linejoin="round" />
        </svg>
        <span class="font-sans text-base font-semibold tracking-[-0.6px] text-ink">
          Student Utility Hub
        </span>
      </a>

      <!-- Desktop Nav Links -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="rounded-full px-3 py-1.5 text-sm font-medium text-body hover:bg-canvas-soft-2 hover:text-ink transition-all duration-150"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <!-- Right Side Actions -->
    <div class="flex items-center gap-3">
      <!-- Dark/Light Toggle -->
      <ThemeToggle />

      <a
        href="/contact"
        class="hidden sm:inline-flex h-8 items-center justify-center rounded-sm bg-primary px-3 text-xs font-semibold text-on-primary hover:bg-ink/90 transition-colors duration-150"
      >
        Feedback
      </a>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-toggle"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink md:hidden focus:outline-none"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg
          class="h-5 w-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Drawer Menu (Initially hidden) -->
  <div
    id="mobile-menu-drawer"
    class="hidden border-b border-hairline bg-canvas px-4 py-4 transition-all duration-200 md:hidden animate-fade-in"
  >
    <nav class="flex flex-col gap-2">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block rounded-md px-3 py-2 text-sm font-medium text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors"
        >
          {link.label}
        </a>
      ))}
      <div class="h-px bg-hairline my-2"></div>
      <a
        href="/contact"
        class="flex h-10 w-full items-center justify-center rounded-sm bg-primary text-sm font-semibold text-on-primary hover:bg-ink/90 transition-colors"
      >
        Send Feedback
      </a>
    </nav>
  </div>
</header>

<script>
  // Mobile menu toggle script
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const menuDrawer = document.getElementById('mobile-menu-drawer');
  const menuIcon = document.getElementById('menu-icon');

  if (toggleBtn && menuDrawer && menuIcon) {
    let isOpen = false;

    toggleBtn.addEventListener('click', () => {
      isOpen = !isOpen;
      toggleBtn.setAttribute('aria-expanded', isOpen.toString());

      if (isOpen) {
        menuDrawer.classList.remove('hidden');
        // Change icon to close (X)
        menuIcon.setAttribute('d', 'M6 18L18 6M6 6l12 12');
      } else {
        menuDrawer.classList.add('hidden');
        // Change icon back to hamburger
        menuIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
      }
    });

    // Close mobile drawer on resize to desktop size
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768 && isOpen) {
        isOpen = false;
        menuDrawer.classList.add('hidden');
        toggleBtn.setAttribute('aria-expanded', 'false');
        menuIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
      }
    });
  }
</script>
